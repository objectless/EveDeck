<Window x:Class="EveWindowCommander.Views.ActiveFrameOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Left="-10000" Top="-10000"
        Width="100" Height="100">
  <Grid>
    <!-- Feathered frame: a stroked rectangle centred on the window edge, softened
         with a blur so it reads as a glow that fades inward rather than a hard line. -->
    <Rectangle x:Name="FrameRect" Fill="Transparent" StrokeThickness="8">
      <Rectangle.Effect>
        <BlurEffect x:Name="FrameBlur" Radius="6" KernelType="Gaussian"/>
      </Rectangle.Effect>
    </Rectangle>
  </Grid>
</Window>
