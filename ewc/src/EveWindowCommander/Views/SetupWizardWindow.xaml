<Window x:Class="EveWindowCommander.Views.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EVE Window Commander — Setup"
        Width="600" Height="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="{StaticResource BgBrush}">

  <WindowChrome.WindowChrome>
    <WindowChrome CaptionHeight="42" ResizeBorderThickness="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
  </WindowChrome.WindowChrome>

  <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="42"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Custom title bar -->
      <Border Grid.Row="0" BorderThickness="0,0,0,1">
        <Border.Background>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#080B12" Offset="0"/>
            <GradientStop Color="#0A0F18" Offset="0.7"/>
            <GradientStop Color="#0C141F" Offset="1"/>
          </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#2BC0E4" Offset="0"/>
            <GradientStop Color="#1B4658" Offset="0.5"/>
            <GradientStop Color="#1F2C3A" Offset="1"/>
          </LinearGradientBrush>
        </Border.BorderBrush>
        <DockPanel>
          <Button Style="{StaticResource CloseButton}"
                  Click="CloseButton_Click"
                  DockPanel.Dock="Right"
                  WindowChrome.IsHitTestVisibleInChrome="True"
                  ToolTip="Cancel">
            <TextBlock Text="&#x2715;" FontSize="12"/>
          </Button>
          <StackPanel Orientation="Horizontal" Margin="14,0" VerticalAlignment="Center">
            <Image Source="/Assets/ewc-mark.png" Width="22" Height="22"
                   Margin="0,0,8,0" VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock Text="Setup Wizard" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
            <TextBlock Text="  EVE Window Commander"
                       Foreground="{StaticResource MutedBrush}"
                       Margin="4,0,0,0"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- Content -->
      <Grid Grid.Row="1" Margin="24,20,24,20">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Step header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,4">
          <TextBlock Text="{Binding StepTitle}" FontSize="18" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding StepIndicator}" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Height="1" Background="{StaticResource BorderBrush}" Margin="0,10,0,16"/>

        <!-- Step content -->
        <Grid Grid.Row="2">

          <!-- Step 0: client count -->
          <StackPanel Visibility="{Binding IsClientStep, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="How many EVE clients will you run at once?"
                       FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
            <ComboBox ItemsSource="{Binding ClientCountOptions}"
                      SelectedItem="{Binding ClientCount}"
                      Width="120" HorizontalAlignment="Left"
                      MaxDropDownHeight="280"/>
            <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,16,0,0">
              <TextBlock Text="{Binding ClientCountDescription}" TextWrapping="Wrap"
                         Foreground="{StaticResource TextBrush}" LineHeight="20"/>
            </Border>
            <TextBlock Margin="0,14,0,0" Foreground="{StaticResource MutedBrush}" FontSize="11" TextWrapping="Wrap">
              Each slot maps to one EVE account (main character + up to 2 alts). You can add, remove, or reassign slots any time from the Clients tab.
            </TextBlock>
          </StackPanel>

          <!-- Step 1: monitor -->
          <StackPanel Visibility="{Binding IsMonitorStep, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Which monitor should the clients be placed on?"
                       FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <TextBlock Text="No monitors were detected. Connect a display and reopen setup."
                       Foreground="#FCA5A5" TextWrapping="Wrap"
                       Visibility="{Binding NoMonitors, Converter={StaticResource BoolToVis}}"/>

            <ComboBox ItemsSource="{Binding Monitors}"
                      SelectedItem="{Binding SelectedMonitor}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding DeviceName}" FontWeight="SemiBold"/>
                    <TextBlock Margin="8,0,0,0" Foreground="{StaticResource MutedBrush}">
                      <Run Text="{Binding Bounds.Width, Mode=OneWay}"/><Run Text="×"/><Run Text="{Binding Bounds.Height, Mode=OneWay}"/>
                      <Run Text="  •  "/><Run Text="{Binding ScalePercent, Mode=OneWay}"/><Run Text="%"/>
                    </TextBlock>
                    <TextBlock Text="  (primary)" Foreground="{StaticResource AccentBrush}"
                               Visibility="{Binding IsPrimary, Converter={StaticResource BoolToVis}}"/>
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <Border Background="#2A2113" BorderBrush="#7A5C1E" BorderThickness="1" CornerRadius="6"
                    Padding="14" Margin="0,16,0,0"
                    Visibility="{Binding HasMonitorWarning, Converter={StaticResource BoolToVis}}">
              <TextBlock Text="{Binding MonitorWarning}" TextWrapping="Wrap" Foreground="#FCD9A0" LineHeight="20"/>
            </Border>
          </StackPanel>

          <!-- Step 2: slot character assignment via ESI -->
          <StackPanel Visibility="{Binding IsEsiStep, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Link your EVE characters (optional)"
                       FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,10" LineHeight="19">
Press "+ Add via ESI" on a slot to sign in with EVE SSO and attach a character. Each slot is one account: a main plus up to 2 alts. The first character you add becomes your MASTER - the account kept centred at rest. You can skip this and link characters later from the Clients tab.
            </TextBlock>
            <ScrollViewer MaxHeight="310" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding WizardSlots}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                          <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                            <Border Background="#6B2F08" CornerRadius="3" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding IsMaster, Converter={StaticResource BoolToVis}}">
                              <TextBlock Text="MASTER" Foreground="#F59E0B" FontSize="9" FontWeight="Bold"/>
                            </Border>
                          </StackPanel>
                          <ItemsControl ItemsSource="{Binding EsiCharacters}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Grid Margin="0,2">
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                  </Grid.ColumnDefinitions>
                                  <Ellipse Grid.Column="0" Width="22" Height="22" Margin="0,0,7,0" VerticalAlignment="Center">
                                    <Ellipse.Fill>
                                      <ImageBrush ImageSource="{Binding PortraitUrlSmall}" Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                  </Ellipse>
                                  <Border Grid.Column="1" Background="#0E2A47" CornerRadius="3" Padding="4,1" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <TextBlock Text="ESI" Foreground="#2BC0E4" FontSize="10" FontWeight="SemiBold"/>
                                  </Border>
                                  <TextBlock Grid.Column="2" Text="{Binding CharacterName}" VerticalAlignment="Center" FontSize="12"/>
                                  <Button Grid.Column="3" Content="×" FontSize="11" Padding="5,1"
                                          Background="Transparent" Foreground="#F87171" BorderThickness="0"
                                          Command="{Binding DataContext.RemoveWizardEsiCharacterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                          CommandParameter="{Binding}"/>
                                </Grid>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                        <Button Grid.Column="1" Content="+ Add via ESI" Padding="8,4" VerticalAlignment="Top"
                                Command="{Binding DataContext.AddWizardEsiCharacterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </StackPanel>

          <!-- Step 3: summary -->
          <StackPanel Visibility="{Binding IsSummaryStep, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Ready to apply" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
            <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="14">
              <TextBlock Text="{Binding SummaryText}" TextWrapping="Wrap" LineHeight="22"/>
            </Border>
            <CheckBox Content="Use high-quality GPU previews for the corner tiles"
                      IsChecked="{Binding UseWgc}" Margin="0,14,0,0"
                      Visibility="{Binding IsCenterMaster, Converter={StaticResource BoolToVis}}"/>
            <CheckBox Content="Click a preview tile to bring that client to the center"
                      IsChecked="{Binding FocusPreviewOnClick}" Margin="0,10,0,0"
                      Visibility="{Binding IsCenterMaster, Converter={StaticResource BoolToVis}}"/>
          </StackPanel>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
          <Button Content="Cancel" HorizontalAlignment="Left" Click="Cancel_Click" MinWidth="90"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Back" Click="Back_Click" MinWidth="90"
                    IsEnabled="{Binding CanGoBack}"/>
            <Button Content="{Binding NextButtonText}" Click="Next_Click" MinWidth="110"
                    Style="{StaticResource AccentButton}"
                    IsEnabled="{Binding CanGoNext}"/>
          </StackPanel>
        </Grid>
      </Grid>
    </Grid>
  </Border>
</Window>
