<Window x:Class="EveDeck.Views.LayoutEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="#7A05080C"
        Topmost="True"
        ShowInTaskbar="False"
        Left="-10000" Top="-10000"
        Width="200" Height="200"
        Focusable="True"
        KeyDown="OnKeyDown">
  <Grid>
    <!-- Slot rectangles are added to this canvas from code-behind. -->
    <Canvas x:Name="EditorCanvas"
            Background="Transparent"
            MouseLeftButtonDown="OnCanvasMouseDown"
            MouseMove="OnCanvasMouseMove"
            MouseLeftButtonUp="OnCanvasMouseUp"/>

    <!-- Floating toolbar -->
    <Border VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,14,0,0"
            Background="#F2141A22" BorderBrush="#3D4B5C" BorderThickness="1" CornerRadius="8" Padding="14,10">
      <StackPanel>
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="Layout Editor" Foreground="#EAF2FF" FontSize="15" FontWeight="SemiBold"
                     VerticalAlignment="Center" Margin="0,0,16,0"/>
          <Button x:Name="AddButton" Content="Add Slot" Click="OnAddSlot" Padding="10,4" Margin="0,0,6,0"/>
          <Button x:Name="DeleteButton" Content="Delete Selected" Click="OnDeleteSlot" Padding="10,4" Margin="0,0,14,0"/>
          <CheckBox x:Name="SnapEdgesCheck" Content="Snap to edges" IsChecked="True"
                    Foreground="#C9D6E8" VerticalAlignment="Center" Margin="0,0,10,0"/>
          <CheckBox x:Name="SnapGridCheck" Content="Snap to grid" IsChecked="True"
                    Foreground="#C9D6E8" VerticalAlignment="Center" Margin="0,0,14,0"/>
          <Button Content="Save" Click="OnSave" Padding="14,4" Margin="0,0,6,0" FontWeight="SemiBold"/>
          <Button Content="Cancel" Click="OnCancel" Padding="10,4"/>
        </StackPanel>
        <TextBlock Foreground="#8CA0B8" FontSize="11" Margin="0,7,0,0"
                   Text="Drag a slot to move it (across any monitor). Drag its edges or corners to resize. Click to select, Delete removes, Enter saves, Esc cancels. Stacked slots are fanned apart so you can grab them."/>
      </StackPanel>
    </Border>
  </Grid>
</Window>
