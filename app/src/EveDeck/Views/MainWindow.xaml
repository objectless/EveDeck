<Window x:Class="EveDeck.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="EveDeck"
        Icon="/Assets/evedeck-mark.png"
        Width="1200"
        Height="800"
        WindowStyle="None"
        ResizeMode="CanResize"
        SourceInitialized="Window_SourceInitialized">

  <WindowChrome.WindowChrome>
    <WindowChrome CaptionHeight="42" ResizeBorderThickness="6" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
  </WindowChrome.WindowChrome>

  <!-- The IndexToVisibility converter is registered in App.Main rather than declared here: any
       XAML reference to a local clr-namespace forces WPF's second markup-compile pass, which
       builds a throwaway *_wpftmp project on every build (see App.xaml.cs). -->

  <!-- Thin visible window border -->
  <Border x:Name="RootContent" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
    <Grid>
      <!-- Atmospheric dark overlay: deep space blue-black vignette with a faint EVE-cyan tint -->
      <Rectangle IsHitTestVisible="False">
        <Rectangle.Fill>
          <RadialGradientBrush GradientOrigin="0.5,0.3" Center="0.5,0.3" RadiusX="0.75" RadiusY="0.75">
            <GradientStop Color="#00050810" Offset="0"/>
            <GradientStop Color="#C8050810" Offset="1"/>
          </RadialGradientBrush>
        </Rectangle.Fill>
      </Rectangle>
      <!-- Subtle cyan edge bleed at top — EVE HUD chrome feel -->
      <Rectangle Height="120" VerticalAlignment="Top" IsHitTestVisible="False">
        <Rectangle.Fill>
          <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0C0E1D2E" Offset="0"/>
            <GradientStop Color="#00050810" Offset="1"/>
          </LinearGradientBrush>
        </Rectangle.Fill>
      </Rectangle>
    <DockPanel>

      <!-- ═══ Custom Title Bar (42 px, acts as drag area) ═══ -->
      <Border DockPanel.Dock="Top"
              Height="42"
              BorderThickness="0,0,0,1">
        <Border.Background>
          <!-- Subtle deep-space gradient with a faint cyan wash on the right, evoking EVE's HUD chrome. -->
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#080B12" Offset="0"/>
            <GradientStop Color="#0A0F18" Offset="0.7"/>
            <GradientStop Color="#0C141F" Offset="1"/>
          </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
          <!-- Cyan-to-dark underline: a thin holographic accent line under the title bar. -->
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#2BC0E4" Offset="0"/>
            <GradientStop Color="#1B4658" Offset="0.5"/>
            <GradientStop Color="#1F2C3A" Offset="1"/>
          </LinearGradientBrush>
        </Border.BorderBrush>
        <DockPanel>
          <!-- Chrome buttons – must be hit-test visible inside caption area -->
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
            <!-- App master brand: the centered account's portrait + name -->
            <Border Background="{StaticResource BrandChipBrush}" CornerRadius="13" Padding="3,2,11,2" Margin="0,0,14,0"
                    VerticalAlignment="Center"
                    Visibility="{Binding HasMasterCharacter, Converter={StaticResource BoolToVis}}"
                    ToolTip="App master - the account centered at rest"
                    WindowChrome.IsHitTestVisibleInChrome="True">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="22" Height="22" Margin="0,0,7,0" Style="{StaticResource PortraitDot}"
                         Visibility="{Binding HasMasterPortrait, Converter={StaticResource BoolToVis}}">
                  <Ellipse.Fill>
                    <ImageBrush ImageSource="{Binding MasterPortrait.Image}" Stretch="UniformToFill"/>
                  </Ellipse.Fill>
                </Ellipse>
                <TextBlock Text="MASTER" Foreground="{StaticResource MasterAccentBrush}" FontSize="9" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding MasterCharacterName}" FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
              </StackPanel>
            </Border>
            <TextBlock Text="{Binding VersionText}"
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       WindowChrome.IsHitTestVisibleInChrome="True"/>
            <Button Style="{StaticResource CaptionButton}"
                    Click="HelpButton_Click"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    ToolTip="New here? See the tab guide on the About tab.">
              <TextBlock Text="?" FontSize="13" FontWeight="Bold" Margin="0,0,0,0"/>
            </Button>
            <Button Style="{StaticResource CaptionButton}"
                    Click="MinimizeButton_Click"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    ToolTip="Minimize">
              <TextBlock Text="&#x2212;" FontSize="16" Margin="0,1,0,0"/>
            </Button>
            <Button Style="{StaticResource CaptionButton}"
                    Click="MaximizeButton_Click"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    ToolTip="Maximize / Restore">
              <TextBlock Text="&#x25A1;" FontSize="12"/>
            </Button>
            <Button Style="{StaticResource CloseButton}"
                    Click="CloseButton_Click"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    ToolTip="Close">
              <TextBlock Text="&#x2715;" FontSize="12"/>
            </Button>
          </StackPanel>

          <!-- App title – remaining area is the drag handle -->
          <StackPanel Orientation="Horizontal" Margin="14,0" VerticalAlignment="Center">
            <Image Source="/Assets/evedeck-mark.png" Width="28" Height="28"
                   Margin="0,0,8,0" VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock Text="EveDeck" FontWeight="SemiBold" FontSize="13"
                       VerticalAlignment="Center"/>
            <TextBlock Text="  Multibox toolkit for EVE Online"
                       Foreground="{StaticResource MutedBrush}"
                       Margin="8,0,0,0"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- ═══ Update Banner ═══ -->
      <Border DockPanel.Dock="Top"
              Background="#0D1A2A"
              BorderBrush="#2BC0E4"
              BorderThickness="0,0,0,1"
              Padding="14,5"
              Visibility="{Binding ShowUpdateBanner, Converter={StaticResource BoolToVis}}">
        <DockPanel>
          <Button DockPanel.Dock="Right"
                  Command="{Binding DismissUpdateBannerCommand}"
                  Background="Transparent" BorderThickness="0"
                  Foreground="{StaticResource MutedBrush}"
                  FontSize="14" Padding="8,0" Cursor="Hand"
                  ToolTip="Dismiss">&#x2715;</Button>
          <Button DockPanel.Dock="Right"
                  Command="{Binding InstallUpdateCommand}"
                  Background="#163527" Foreground="#22C55E"
                  BorderThickness="0"
                  FontSize="11" FontWeight="SemiBold"
                  Padding="10,4" Margin="0,0,8,0" Cursor="Hand"
                  ToolTip="Update now">Update</Button>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="&#xE8A9;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                       Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="{Binding UpdateVersionText}"
                       Foreground="{StaticResource TextBrush}" FontSize="12" VerticalAlignment="Center"/>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- ═══ Config Reset Banner ═══ -->
      <Border DockPanel.Dock="Top"
              Background="#2A1608"
              BorderBrush="#F59E0B"
              BorderThickness="0,0,0,1"
              Padding="14,5"
              Visibility="{Binding ShowConfigResetBanner, Converter={StaticResource BoolToVis}}">
        <DockPanel>
          <Button DockPanel.Dock="Right"
                  Command="{Binding DismissConfigResetBannerCommand}"
                  Background="Transparent" BorderThickness="0"
                  Foreground="{StaticResource MutedBrush}"
                  FontSize="14" Padding="8,0" Cursor="Hand"
                  ToolTip="Dismiss">&#x2715;</Button>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                       Foreground="#F59E0B" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="Your settings file appeared to be corrupted and was reset to defaults. A backup was saved automatically — open Options → Backups to restore your previous settings."
                       Foreground="{StaticResource TextBrush}" FontSize="12" VerticalAlignment="Center"
                       TextWrapping="Wrap" MaxWidth="760"/>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- ═══ Hotkey Conflict Banner ═══ -->
      <Border DockPanel.Dock="Top"
              Background="#2A1608"
              BorderBrush="#F59E0B"
              BorderThickness="0,0,0,1"
              Padding="14,5"
              Visibility="{Binding ShowHotkeyConflictBanner, Converter={StaticResource BoolToVis}}">
        <DockPanel>
          <Button DockPanel.Dock="Right"
                  Command="{Binding DismissHotkeyConflictBannerCommand}"
                  Background="Transparent" BorderThickness="0"
                  Foreground="{StaticResource MutedBrush}"
                  FontSize="14" Padding="8,0" Cursor="Hand"
                  ToolTip="Dismiss">&#x2715;</Button>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                       Foreground="#F59E0B" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="{Binding HotkeyConflictMessage}"
                       Foreground="{StaticResource TextBrush}" FontSize="12" VerticalAlignment="Center"
                       TextWrapping="Wrap" MaxWidth="760"/>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- ═══ Status Bar ═══ -->
      <Border DockPanel.Dock="Bottom"
              Background="#0A0D14"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="0,1,0,0"
              Padding="10,5">
        <DockPanel>
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
            <CheckBox Content="Auto-refresh" IsChecked="{Binding AutoRefresh}" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="{Binding LastUpdatedText}" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse Width="8" Height="8" Fill="{Binding DetectionStateColor}" VerticalAlignment="Center" Margin="0,0,7,0"/>
            <TextBlock Text="{Binding DetectionStateText}" FontWeight="SemiBold"/>
            <TextBlock Text="  Windows: " Foreground="{StaticResource MutedBrush}" Margin="14,0,0,0"/>
            <TextBlock Text="{Binding WindowCount}"/>
            <TextBlock Text="  Monitors: " Foreground="{StaticResource MutedBrush}" Margin="14,0,0,0"/>
            <TextBlock Text="{Binding MonitorCount}"/>
            <Border Width="1" Background="{StaticResource BorderBrush}" Margin="14,2,14,2"/>
            <TextBlock Text="&#xE8A9;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                       Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBlock Text="{Binding SelectedProfile.Name, FallbackValue='No profile', TargetNullValue='No profile'}"
                       FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock Text="   " />
            <TextBlock Text="{Binding Status}" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- ═══ Tab Control ═══ -->
      <TabControl x:Name="MainTabControl" BorderThickness="0" SelectionChanged="MainTabControl_SelectionChanged">

        <!-- The default TabPanel wraps the strip onto a second line once the window is narrower than
             the tabs need. A StackPanel never wraps; Window_SourceInitialized then measures the strip
             and raises MinWidth so the window can't be sized small enough to clip it. -->
        <TabControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel x:Name="TabStrip" Orientation="Horizontal" IsItemsHost="True"/>
          </ItemsPanelTemplate>
        </TabControl.ItemsPanel>

        <!-- ──────────────────── CLIENTS TAB ──────────────────── -->
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center"/>
              <TextBlock Text="Clients" VerticalAlignment="Center"/>
            </StackPanel>
          </TabItem.Header>
          <Grid Margin="12">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Section header -->
            <DockPanel Margin="0,0,0,10">
              <!-- Center, not the default Stretch: otherwise the buttons grow to the height of the
                   two-line title block opposite them. -->
              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Auto-Assign All" Command="{Binding AutoAssignAllCommand}" ToolTip="Assign all unassigned detected windows to empty slots in order"/>
                <Button Content="Refresh" Command="{Binding RefreshCommand}"/>
                <Button Content="Refresh Portraits" Command="{Binding RefreshPortraitsCommand}"
                        ToolTip="Re-download every cached character portrait, in case one changed in-game."/>
                <Button Content="Toggle Borderless" Command="{Binding ToggleSelectedBorderlessCommand}"/>
                <Button Content="Restore Style" Command="{Binding RestoreSelectedStyleCommand}"/>
              </StackPanel>
              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Clients" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="Pick an EVE window on the left, then click Assign next to the slot you want it to use. New clients can be matched automatically with Auto-Assign All."
                           Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,3,0,0" TextWrapping="Wrap"/>
              </StackPanel>
            </DockPanel>

            <!-- Two-column split. The left column is a fixed width rather than a proportion so the
                 window list stops reflowing every time the window is resized; Slots absorbs the slack,
                 which is where day-to-day work actually happens. -->
            <Grid Grid.Row="1">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <!-- LEFT: Detected Windows panel -->
              <Border Background="{StaticResource PanelBrush}"
                      BorderBrush="{StaticResource BorderBrush}"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="10">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="*"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Height="28" Margin="0,0,0,8">
                      <Border DockPanel.Dock="Right" CornerRadius="9" MinWidth="18" Height="18" Padding="5,0"
                              Background="{StaticResource AccentBrush}" VerticalAlignment="Center">
                        <Border.Style>
                          <Style TargetType="Border">
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding UnassignedWindowCount}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding UnassignedWindowCount}" FontSize="10" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   ToolTip="Unassigned detected windows"/>
                      </Border>
                      <TextBlock Text="Detected Windows" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </DockPanel>

                    <!-- Test-window controls live below the header rather than beside it: at a fixed
                         340px column they no longer fit on the header line. -->
                    <DockPanel Grid.Row="1" Margin="0,0,0,8">
                      <CheckBox DockPanel.Dock="Bottom"
                                Content="Include Notepad test windows"
                                IsChecked="{Binding IncludeNotepadTestWindows}"
                                Margin="0,6,0,0"/>
                      <Button Content="Spawn Test Windows"
                              Command="{Binding SpawnTestWindowsCommand}"
                              ToolTip="Open one Notepad window per slot, titled 'EveDeck TEST - Slot N', so you can test layout placement without EVE running."
                              HorizontalAlignment="Stretch"
                              Margin="0"/>
                    </DockPanel>

                    <!-- Window list with empty state overlay -->
                    <Grid Grid.Row="2">
                    <ListBox x:Name="WindowsListBox"
                           ItemsSource="{Binding WindowsView}"
                           SelectedItem="{Binding SelectedWindow}"
                           PreviewMouseLeftButtonDown="WindowsListBox_PreviewMouseLeftButtonDown"
                           PreviewMouseMove="WindowsListBox_PreviewMouseMove">
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Border Padding="10,9" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                              </Grid.ColumnDefinitions>
                              <StackPanel>
                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0" FontSize="11">
                                  <Run Text="PID "/><Run Text="{Binding ProcessId, Mode=OneWay}"/><Run Text="   HWND "/><Run Text="{Binding HandleHex, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="11">
                                  <Run Text="Rect "/><Run Text="{Binding Rect, Mode=OneWay}"/><Run Text="   Monitor "/><Run Text="{Binding MonitorId, Mode=OneWay}"/>
                                </TextBlock>
                              </StackPanel>
                              <!-- Borderless badge -->
                              <Border Grid.Column="1" CornerRadius="3" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                <Border.Style>
                                  <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Background" Value="#122B1A"/>
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding IsBorderless}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </Border.Style>
                                <TextBlock Text="borderless" Foreground="#22C55E" FontSize="11" FontWeight="SemiBold"/>
                              </Border>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Empty state overlay -->
                    <Border CornerRadius="4" Background="{StaticResource PanelBrush}">
                      <Border.Style>
                        <Style TargetType="Border">
                          <Setter Property="Visibility" Value="Collapsed"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding HasNoWindows}" Value="True">
                              <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="No EVE windows detected"
                                   FontSize="15" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}"/>
                        <TextBlock Text="Start EVE Online, then click Refresh."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"/>
                        <TextBlock Text="Enable 'Include Notepad test windows' to test without EVE."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                      </StackPanel>
                    </Border>

                    <!-- All-assigned empty state: distinct from "none detected" above, this is the
                         common steady state (everything's already placed) that used to render as a
                         blank box with no explanation at all. -->
                    <Border CornerRadius="4" Background="{StaticResource PanelBrush}">
                      <Border.Style>
                        <Style TargetType="Border">
                          <Setter Property="Visibility" Value="Collapsed"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding AllWindowsAssigned}" Value="True">
                              <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="All detected windows are assigned"
                                   FontSize="15" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}"/>
                        <TextBlock Text="Launch another client and click Refresh to see it here."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"/>
                      </StackPanel>
                    </Border>
                    </Grid>

                    <TextBlock Grid.Row="3" Text="{Binding Status}"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="11"
                               Margin="2,8,2,0"
                               TextTrimming="CharacterEllipsis"/>
                  </Grid>
              </Border>

              <!-- RIGHT: Slots panel -->
              <Border Grid.Column="2"
                      Background="{StaticResource PanelBrush}"
                      BorderBrush="{StaticResource BorderBrush}"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="10">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                  </Grid.RowDefinitions>

                  <!-- Character Set switcher -->
                  <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                      <Button Content="+ Set" Command="{Binding AddCharacterSetCommand}" Padding="7,3" FontSize="11" ToolTip="Add a new character set (clones slot/hotkey structure, empty window assignments)"/>
                      <Button Content="Del" Command="{Binding DeleteCharacterSetCommand}" Padding="7,3" FontSize="11" Margin="4,0,0,0" Style="{StaticResource DangerButton}" ToolTip="Delete the active character set"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center">
                      <TextBlock Text="Character Sets" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,3"/>
                      <ItemsControl ItemsSource="{Binding CharacterSets}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,0,4,4">
                              <ToggleButton Padding="10,3" FontSize="11" MinHeight="0"
                                            Content="{Binding Name}"
                                            IsChecked="{Binding IsActive, Mode=OneWay}"
                                            Command="{Binding DataContext.SwitchCharacterSetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                <ToggleButton.Style>
                                  <Style TargetType="ToggleButton">
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                      <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                          <Border x:Name="bd" CornerRadius="4" Padding="{TemplateBinding Padding}"
                                                  Background="{StaticResource ButtonBrush}"
                                                  BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                          </Border>
                                          <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="False">
                                              <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                              <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                              <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                              <Setter Property="Foreground" Value="White"/>
                                              <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                              <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                            </Trigger>
                                          </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                      </Setter.Value>
                                    </Setter>
                                  </Style>
                                </ToggleButton.Style>
                              </ToggleButton>
                              <Button Content="Launch" Padding="7,3" FontSize="11" MinHeight="0" Margin="2,0,0,0"
                                      Command="{Binding DataContext.LaunchGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                      CommandParameter="{Binding}"
                                      ToolTip="Launch the EVE Launcher once per named seat in this group, spaced out by its launch delay"/>
                            </StackPanel>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </DockPanel>

                  <DockPanel Grid.Row="1" Margin="0,0,0,8">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                      <Button Content="Add Slot" Command="{Binding AddSlotCommand}"/>
                      <Button Content="Delete" Command="{Binding DeleteSelectedSlotCommand}" Style="{StaticResource DangerButton}"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center">
                      <TextBlock Text="Slots" FontSize="15" FontWeight="SemiBold"/>
                      <TextBlock Text="Each slot is one seat. Assign a window, then drag a slot's ⠿ grip onto the mini-map to set its corner — or drop on the center to make it Master."
                                 Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"/>
                      <TextBlock Text="Position codes:  ⌜⌝⌞⌟ = screen corners   ▲▼◀▶ = edges   ★ = Master (home seat)"
                                 Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                  </DockPanel>

                  <!-- Layout minimap: drag an EVE window onto a cell to assign it, or drag a slot card's grip
                       onto a corner to set that seat's home corner (center cell = Master). -->
                  <Border Grid.Row="2" Margin="0,0,0,8" HorizontalAlignment="Center" Padding="4"
                          Background="#080D14" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                    <Border.Style>
                      <Style TargetType="Border">
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding MiniMapSlots.Count}" Value="0">
                            <Setter Property="Visibility" Value="Collapsed"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Border.Style>
                    <Canvas Width="340" Height="216" ClipToBounds="True">
                      <ItemsControl ItemsSource="{Binding MiniMapSlots}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <Canvas/>
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                          <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                            <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                          </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Width="{Binding Width}" Height="{Binding Height}"
                                    AllowDrop="True"
                                    DragEnter="MiniMapSlot_DragEnter"
                                    DragOver="MiniMapSlot_DragOver"
                                    DragLeave="MiniMapSlot_DragLeave"
                                    Drop="MiniMapSlot_Drop"
                                    ToolTip="Drag a slot card (using its ⠿ grip) here to set its corner. Drop on the center to make it Master."
                                    CornerRadius="2">
                              <Border.Style>
                                <Style TargetType="Border">
                                  <Setter Property="Background" Value="#0F1A2B"/>
                                  <Setter Property="BorderBrush" Value="#2B3D55"/>
                                  <Setter Property="BorderThickness" Value="1"/>
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAssigned}" Value="True">
                                      <Setter Property="Background" Value="#132540"/>
                                      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMaster}" Value="True">
                                      <Setter Property="Background" Value="#2A1606"/>
                                      <Setter Property="BorderBrush" Value="#F59E0B"/>
                                      <Setter Property="BorderThickness" Value="2"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsDragOver}" Value="True">
                                      <Setter Property="Background" Value="#1C3B57"/>
                                      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                      <Setter Property="BorderThickness" Value="2"/>
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </Border.Style>
                              <Grid ClipToBounds="True">
                                <TextBlock Text="{Binding PositionCode}" FontSize="10" Padding="3,1"
                                           HorizontalAlignment="Right" VerticalAlignment="Top"
                                           Foreground="#5C84B0"/>
                                <TextBlock Text="{Binding AssignedLabel}" FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" TextWrapping="Wrap" Padding="4,0">
                                  <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                      <Setter Property="Foreground" Value="#3A5070"/>
                                      <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAssigned}" Value="True">
                                          <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                        </DataTrigger>
                                      </Style.Triggers>
                                    </Style>
                                  </TextBlock.Style>
                                </TextBlock>
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Canvas>
                  </Border>

                  <ListBox x:Name="SlotsListBox" Grid.Row="3"
                           PreviewKeyDown="SlotsListBox_PreviewKeyDown"
                           ItemsSource="{Binding Assignments}"
                           SelectedItem="{Binding SelectedAssignment}"
                           VirtualizingPanel.ScrollUnit="Pixel"
                           VirtualizingPanel.IsVirtualizing="True"
                           ScrollViewer.CanContentScroll="True"
                           ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <StackPanel AllowDrop="True"
                                    DragEnter="SlotCard_DragEnter"
                                    DragLeave="SlotCard_DragLeave"
                                    DragOver="SlotCard_DragOver"
                                    Drop="SlotCard_Drop">

                          <Border x:Name="SlotCardBorder" Padding="8,7">
                            <Border.Style>
                              <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                  <!-- Drop lands via Assignments.Move (insert, not swap), so show an
                                       insert line on the leading edge rather than boxing the card. -->
                                  <DataTrigger Binding="{Binding IsDragSwapTarget}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                    <Setter Property="BorderThickness" Value="0,2,0,0"/>
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </Border.Style>
                            <Grid>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="Auto" MinWidth="34"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                              </Grid.ColumnDefinitions>

                              <!-- Drag handle -->
                              <!-- Full-height transparent grab strip: the glyph alone was a ~15x18px
                                   hit target. Background="Transparent" is required for hit-testing. -->
                              <Border Grid.Column="0" Background="Transparent" Cursor="SizeAll"
                                      VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                      ToolTip="Drag to reorder seats, or drop onto the mini-map to set this seat's corner. Alt+Up / Alt+Down reorders with the keyboard."
                                      PreviewMouseLeftButtonDown="SlotHandle_MouseDown"
                                      MouseMove="SlotHandle_MouseMove">
                                <TextBlock Text="⠿" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center">
                                  <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                      <Setter Property="Foreground" Value="#3A4A65"/>
                                      <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                          <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        </DataTrigger>
                                      </Style.Triggers>
                                    </Style>
                                  </TextBlock.Style>
                                </TextBlock>
                              </Border>

                              <!-- Position-code pill -->
                              <Border Grid.Column="1" MinWidth="26" Height="26" CornerRadius="13" Padding="7,0"
                                      VerticalAlignment="Center" HorizontalAlignment="Left"
                                      ToolTip="Screen position in the active layout (&#x2196; top-left, &#x2197; top-right, &#x2199; bottom-left, &#x2198; bottom-right, Master = main client)">
                                <Border.Style>
                                  <Style TargetType="Border">
                                    <Setter Property="Background" Value="#1E2A3D"/>
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding IsAssigned}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource OnlineChipBrush}"/>
                                      </DataTrigger>
                                      <DataTrigger Binding="{Binding IsMaster}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource MasterChipBrush}"/>
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding PositionCode}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontWeight="Bold" FontSize="11">
                                  <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                      <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                                      <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAssigned}" Value="True">
                                          <Setter Property="Foreground" Value="{StaticResource OnlineBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMaster}" Value="True">
                                          <Setter Property="Foreground" Value="{StaticResource MasterAccentBrush}"/>
                                        </DataTrigger>
                                      </Style.Triggers>
                                    </Style>
                                  </TextBlock.Style>
                                </TextBlock>
                              </Border>

                              <!-- Label + character/window info -->
                              <StackPanel Grid.Column="2" Margin="8,0" VerticalAlignment="Center">
                                <!-- Slot name row -->
                                <DockPanel>
                                  <Border DockPanel.Dock="Right" Background="{StaticResource MasterChipBrush}" CornerRadius="3" Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center"
                                          ToolTip="This seat is the Master (home) seat.">
                                    <Border.Style>
                                      <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                          <DataTrigger Binding="{Binding IsMaster}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                          </DataTrigger>
                                        </Style.Triggers>
                                      </Style>
                                    </Border.Style>
                                    <TextBlock Text="MASTER" Foreground="{StaticResource MasterAccentBrush}" FontSize="9" FontWeight="Bold"/>
                                  </Border>
                                  <!-- Always-on-top pin toggle -->
                                  <ToggleButton DockPanel.Dock="Right"
                                                IsChecked="{Binding IsTopmost, Mode=TwoWay}"
                                                Command="{Binding DataContext.ToggleTopmostCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Content="&#x1F4CC;" FontSize="12"
                                                Padding="7,1" Margin="4,0,0,0" MinWidth="0" MinHeight="0"
                                                ToolTip="Keep this seat above other windows while EVE is focused. When you switch to a non-EVE app (browser, Discord) it drops back to normal so it doesn't cover them.">
                                    <ToggleButton.Style>
                                      <Style TargetType="ToggleButton">
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                          <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                              <Border x:Name="bd" CornerRadius="3" Padding="{TemplateBinding Padding}"
                                                      Background="Transparent"
                                                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                              </Border>
                                              <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="False">
                                                  <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                  <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                                  <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                  <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                  <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                </Trigger>
                                              </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                          </Setter.Value>
                                        </Setter>
                                      </Style>
                                    </ToggleButton.Style>
                                  </ToggleButton>
                                  <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                           Style="{StaticResource InlineSlotLabel}"
                                           FontSize="14" FontWeight="SemiBold"
                                           ToolTip="Slot label — auto-filled from 'EVE - Name'. Also editable in Options &gt; Character Names."/>
                                </DockPanel>

                                <!-- Style popup: consolidates label font/style/opacity (normal + MASTER) and frame color behind one button -->
                                <StackPanel Margin="0,3,0,0">
                                  <Button x:Name="StyleButton" Content="Style..." Click="SlotStylePopup_Click"
                                          Padding="7,3" MinWidth="0" MinHeight="0" FontSize="10" HorizontalAlignment="Left"
                                          ToolTip="Edit this seat's label font/style/opacity (normal + MASTER) and active-frame color"/>
                                  <Popup x:Name="SeatStylePopup" PlacementTarget="{Binding ElementName=StyleButton}" Placement="Bottom"
                                         StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade"
                                         DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <Border Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="6" Padding="14" MinWidth="360">
                                      <StackPanel>
                                        <TextBlock Text="Normal label" FontWeight="SemiBold" FontSize="11" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                          <Button Content="Font..." Click="SlotLabelFontPick_Click" Padding="6,2" FontSize="10"
                                                  ToolTip="Set this seat's preview label font, size and colour"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                                          <CheckBox Content="Bold" Tag="Bold" Loaded="SlotStyleToggle_Loaded" Click="SlotStyleToggle_Click" Margin="0,0,10,0" FontSize="11" VerticalAlignment="Center"/>
                                          <CheckBox Content="Italic" Tag="Italic" Loaded="SlotStyleToggle_Loaded" Click="SlotStyleToggle_Click" Margin="0,0,10,0" FontSize="11" VerticalAlignment="Center"/>
                                          <CheckBox Content="Shadow" Tag="Shadow" Loaded="SlotStyleToggle_Loaded" Click="SlotStyleToggle_Click" Margin="0,0,10,0" FontSize="11" VerticalAlignment="Center"/>
                                          <CheckBox Content="Outline" Tag="Outline" Loaded="SlotStyleToggle_Loaded" Click="SlotStyleToggle_Click" Margin="0,0,10,0" FontSize="11" VerticalAlignment="Center"/>
                                          <TextBlock Text="Opacity" Margin="0,0,4,0" FontSize="11" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                          <Slider Tag="Opacity" Loaded="SlotOpacitySlider_Loaded" ValueChanged="SlotOpacitySlider_ValueChanged"
                                                  Minimum="20" Maximum="100" Width="100" VerticalAlignment="Center"/>
                                          <Button Content="&#8635;" Click="SlotLabelStyleReset_Click" Padding="5,1" Margin="8,0,0,0" MinWidth="0" MinHeight="0" FontSize="10"
                                                  ToolTip="Reset this seat's label font, style and opacity to the global default"/>
                                        </StackPanel>

                                        <Separator Margin="0,0,0,10"/>

                                        <TextBlock Text="Master label" FontWeight="SemiBold" FontSize="11" Foreground="{StaticResource MasterAccentBrush}" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                          <Button Content="Font..." Click="SlotMasterLabelFontPick_Click" Padding="6,2" FontSize="10"
                                                  ToolTip="Set this seat's label font/size/colour for when it's the centered MASTER seat (falls back to its normal label font when unset)"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                                          <CheckBox Content="Bold" Tag="BoldMaster" Loaded="SlotStyleToggle_Loaded" Click="SlotStyleToggle_Click" Margin="0,0,10,0" FontSize="11" VerticalAlignment="Center"/>
                                          <CheckBox Content="Italic" Tag="ItalicMaster" Loaded="SlotStyleToggle_Loaded" Click="SlotStyleToggle_Click" Margin="0,0,10,0" FontSize="11" VerticalAlignment="Center"/>
                                          <CheckBox Content="Shadow" Tag="ShadowMaster" Loaded="SlotStyleToggle_Loaded" Click="SlotStyleToggle_Click" Margin="0,0,10,0" FontSize="11" VerticalAlignment="Center"/>
                                          <CheckBox Content="Outline" Tag="OutlineMaster" Loaded="SlotStyleToggle_Loaded" Click="SlotStyleToggle_Click" Margin="0,0,10,0" FontSize="11" VerticalAlignment="Center"/>
                                          <TextBlock Text="Opacity" Margin="0,0,4,0" FontSize="11" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                          <Slider Tag="OpacityMaster" Loaded="SlotOpacitySlider_Loaded" ValueChanged="SlotOpacitySlider_ValueChanged"
                                                  Minimum="20" Maximum="100" Width="100" VerticalAlignment="Center"/>
                                          <Button Content="&#8635;" Click="SlotMasterLabelStyleReset_Click" Padding="5,1" Margin="8,0,0,0" MinWidth="0" MinHeight="0" FontSize="10"
                                                  ToolTip="Reset this seat's MASTER label font, style and opacity to the global master default"/>
                                        </StackPanel>

                                        <Separator Margin="0,0,0,10"/>

                                        <TextBlock Text="Active frame" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal">
                                          <Button Content="Color..." Click="SlotFrameColorPick_Click" Padding="6,2" FontSize="10" Margin="0,0,4,0"
                                                  ToolTip="Set this seat's active-window frame colour (the highlight around the focused client)"/>
                                          <Button Content="&#8635;" Click="SlotFrameColorReset_Click" Padding="5,1" MinWidth="0" MinHeight="0" FontSize="10" Margin="0,0,10,0"
                                                  ToolTip="Reset this seat's frame colour to the global default"/>
                                          <Button Content="Paste Theme" Click="SlotPasteTheme_Click" Padding="6,2" FontSize="10"
                                                  ToolTip="Paste a copied EVE 'Edit Theme' string to set this seat's frame + label colour (Primary -&gt; frame, Accent -&gt; label)"/>
                                        </StackPanel>

                                        <Separator Margin="0,10,0,10"/>

                                        <TextBlock Text="Label position and zoom" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                          <TextBlock Text="Label" FontSize="10" VerticalAlignment="Center"
                                                     Foreground="{StaticResource MutedBrush}"/>
                                          <ComboBox Width="96" FontSize="10" Margin="4,0,0,0"
                                                    SelectedValue="{Binding LabelAnchor, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Tag"
                                                    ToolTip="Where this seat's label sits on its small corner tile. Blank = use the global Label position from Options.">
                                            <ComboBoxItem Tag="{x:Null}" Content="(inherit)"/>
                                            <ComboBoxItem Tag="TopLeft" Content="Top left"/>
                                            <ComboBoxItem Tag="TopCenter" Content="Top center"/>
                                            <ComboBoxItem Tag="TopRight" Content="Top right"/>
                                            <ComboBoxItem Tag="MiddleLeft" Content="Middle left"/>
                                            <ComboBoxItem Tag="Center" Content="Center"/>
                                            <ComboBoxItem Tag="MiddleRight" Content="Middle right"/>
                                            <ComboBoxItem Tag="BottomLeft" Content="Bottom left"/>
                                            <ComboBoxItem Tag="BottomCenter" Content="Bottom center"/>
                                            <ComboBoxItem Tag="BottomRight" Content="Bottom right"/>
                                          </ComboBox>
                                          <TextBlock Text="as master" FontSize="10" VerticalAlignment="Center"
                                                     Foreground="{StaticResource MutedBrush}" Margin="6,0,0,0"/>
                                          <ComboBox Width="96" FontSize="10" Margin="4,0,0,0"
                                                    SelectedValue="{Binding LabelAnchorMaster, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Tag"
                                                    ToolTip="Where this seat's label sits when it is the big center/master client. Blank = use the global master position from Options.">
                                            <ComboBoxItem Tag="{x:Null}" Content="(inherit)"/>
                                            <ComboBoxItem Tag="TopLeft" Content="Top left"/>
                                            <ComboBoxItem Tag="TopCenter" Content="Top center"/>
                                            <ComboBoxItem Tag="TopRight" Content="Top right"/>
                                            <ComboBoxItem Tag="MiddleLeft" Content="Middle left"/>
                                            <ComboBoxItem Tag="Center" Content="Center"/>
                                            <ComboBoxItem Tag="MiddleRight" Content="Middle right"/>
                                            <ComboBoxItem Tag="BottomLeft" Content="Bottom left"/>
                                            <ComboBoxItem Tag="BottomCenter" Content="Bottom center"/>
                                            <ComboBoxItem Tag="BottomRight" Content="Bottom right"/>
                                          </ComboBox>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                          <TextBlock Text="zoom" FontSize="10" VerticalAlignment="Center"
                                                     Foreground="{StaticResource MutedBrush}"/>
                                          <TextBox Text="{Binding ZoomFactor, UpdateSourceTrigger=PropertyChanged}"
                                                   Width="34" Padding="4,2" FontSize="10" Margin="4,0,0,0"
                                                   ToolTip="How hard this seat's preview magnifies on hover (1.5-8). Blank = use the global setting. Raise it for the one alt whose HUD you actually need to read."/>
                                          <TextBlock Text="x from" FontSize="10" VerticalAlignment="Center"
                                                     Foreground="{StaticResource MutedBrush}" Margin="6,0,0,0"/>
                                          <ComboBox Width="96" FontSize="10" Margin="4,0,0,0"
                                                    SelectedValue="{Binding ZoomAnchor, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Tag"
                                                    ToolTip="Which point this tile grows from on hover zoom. Useful when a tile sits hard against a screen edge and should expand inward. Blank = use the global setting.">
                                            <ComboBoxItem Tag="{x:Null}" Content="(inherit)"/>
                                            <ComboBoxItem Tag="TopLeft" Content="Top left"/>
                                            <ComboBoxItem Tag="TopCenter" Content="Top center"/>
                                            <ComboBoxItem Tag="TopRight" Content="Top right"/>
                                            <ComboBoxItem Tag="MiddleLeft" Content="Middle left"/>
                                            <ComboBoxItem Tag="Center" Content="Center"/>
                                            <ComboBoxItem Tag="MiddleRight" Content="Middle right"/>
                                            <ComboBoxItem Tag="BottomLeft" Content="Bottom left"/>
                                            <ComboBoxItem Tag="BottomCenter" Content="Bottom center"/>
                                            <ComboBoxItem Tag="BottomRight" Content="Bottom right"/>
                                          </ComboBox>
                                        </StackPanel>
                                      </StackPanel>
                                    </Border>
                                  </Popup>
                                </StackPanel>

                                <!-- Live indicator: who's actually logged into this seat right now, when
                                     it differs from the seat's stable configured Label (e.g. an alt). -->
                                <TextBlock Text="{Binding RunningCharacterName, StringFormat='Running: {0}'}"
                                           FontSize="10" Foreground="{StaticResource MutedBrush}"
                                           ToolTip="Character currently logged into this seat's window.">
                                  <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                      <Setter Property="Visibility" Value="Collapsed"/>
                                      <Style.Triggers>
                                        <MultiDataTrigger>
                                          <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsAssigned}" Value="True"/>
                                          </MultiDataTrigger.Conditions>
                                          <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                      </Style.Triggers>
                                    </Style>
                                  </TextBlock.Style>
                                </TextBlock>

                                <!-- ESI characters -->
                                <ItemsControl ItemsSource="{Binding EsiCharacters}" Margin="0,3,0,0">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                      <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                          <ColumnDefinition Width="Auto"/>
                                          <ColumnDefinition Width="Auto"/>
                                          <ColumnDefinition Width="*"/>
                                          <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="20" Height="20" Margin="0,0,6,0" VerticalAlignment="Center" Style="{StaticResource PortraitDot}">
                                          <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding Portrait.Image}" Stretch="UniformToFill"/>
                                          </Ellipse.Fill>
                                        </Ellipse>
                                        <Border Grid.Column="1" Background="{StaticResource EsiChipBrush}" CornerRadius="3" Padding="4,1" Margin="0,0,5,0" VerticalAlignment="Center"
                                                ToolTip="ESI = EVE character login (SSO). This character is linked to this seat.">
                                          <TextBlock Text="ESI" Foreground="{StaticResource AccentBrush}" FontSize="9" FontWeight="Bold"/>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding CharacterName}" FontSize="11" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                                          <Button Content="↻"
                                                  Command="{Binding DataContext.ReauthEsiCharacterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"
                                                  Padding="4,0" Margin="0" MinWidth="0" MinHeight="0" FontSize="11"
                                                  ToolTip="Re-run EVE SSO login for this character (e.g. to grant a newly added scope like Planetary Industry) without removing it from the seat"/>
                                          <Button Content="×"
                                                  Command="{Binding DataContext.RemoveEsiCharacterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"
                                                  Padding="4,0" Margin="4,0,0,0" MinWidth="0" MinHeight="0" FontSize="11"/>
                                        </StackPanel>
                                      </Grid>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Add ESI + assigned window summary on one compact row -->
                                <DockPanel Margin="0,3,0,0">
                                  <Button DockPanel.Dock="Left"
                                          Content="+ ESI"
                                          Command="{Binding DataContext.AddEsiCharacterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                          CommandParameter="{Binding}"
                                          Padding="5,2" Margin="0,0,6,0" MinHeight="0" FontSize="10"
                                          ToolTip="ESI = EVE character login (SSO). Login with EVE SSO to link a character to this slot (main + up to 2 alts)">
                                    <Button.Style>
                                      <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Style.Triggers>
                                          <DataTrigger Binding="{Binding EsiCharacters.Count}" Value="3">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                          </DataTrigger>
                                        </Style.Triggers>
                                      </Style>
                                    </Button.Style>
                                  </Button>
                                  <!-- Assigned window entries (compact inline) -->
                                  <ItemsControl ItemsSource="{Binding AssignedWindows}">
                                    <ItemsControl.ItemsPanel>
                                      <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate>
                                        <Border Background="#111C2A" CornerRadius="3" Padding="5,2" Margin="0,0,4,0">
                                          <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="×"
                                                    Command="{Binding DataContext.RemoveWindowFromSlotCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="3,0" Margin="3,0,0,0" MinWidth="0" MinHeight="0" FontSize="10"/>
                                            <TextBlock Text="{Binding Title}" FontSize="10"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="140"
                                                       Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                          </DockPanel>
                                        </Border>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </DockPanel>

                                <!-- Unassigned hint -->
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                  <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                      <Setter Property="Visibility" Value="Collapsed"/>
                                      <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAssigned}" Value="False">
                                          <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                      </Style.Triggers>
                                    </Style>
                                  </StackPanel.Style>
                                  <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                             Foreground="{StaticResource WarningBrush}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                  <TextBlock Text="No window linked yet - select an EVE window above, then Assign"
                                             Foreground="{StaticResource MutedBrush}" FontSize="10" VerticalAlignment="Center"/>
                                </StackPanel>
                              </StackPanel>

                              <!-- Action buttons — compact vertical stack -->
                              <StackPanel Grid.Column="3" Width="240" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <StackPanel Orientation="Horizontal">
                                  <Button Content="Assign"
                                          Command="{Binding DataContext.AssignWindowToSlotCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                          CommandParameter="{Binding}" Padding="7,4" Margin="4,2"/>
                                  <Button Content="Focus"
                                          Command="{Binding DataContext.FocusSlotCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                          CommandParameter="{Binding}" Padding="7,4" Margin="4,2"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                  <Button Content="Clear"
                                          Command="{Binding DataContext.ClearSlotCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                          CommandParameter="{Binding}" Padding="6,3" Margin="4,2" FontSize="11"/>
                                  <Button Content="⭐ Master"
                                          Command="{Binding DataContext.SetMasterSlotCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                          CommandParameter="{Binding}" Padding="6,3" Margin="4,2" FontSize="11"
                                          ToolTip="Designate this slot as master for the swap-focused hotkey"/>
                                </StackPanel>
                                <CheckBox Content="Never minimize" FontSize="10" Margin="4,2"
                                          IsChecked="{Binding NeverMinimize, UpdateSourceTrigger=PropertyChanged}"
                                          ToolTip="Protect this seat from the Minimize-all hotkey and auto-minimize (e.g. a scout you always keep visible)"/>
                                <CheckBox Content="Focus only (no master swap)" FontSize="10" Margin="4,2"
                                          IsChecked="{Binding FocusOnlyNoSwap, UpdateSourceTrigger=PropertyChanged}"
                                          ToolTip="Activating this seat (click/hotkey) just brings its window to the front in place, instead of swapping it into the master/center slot. Also disables hover-peek for this seat."/>
                                <CheckBox Content="Hide preview" FontSize="10" Margin="4,2"
                                          IsChecked="{Binding PreventPreview, UpdateSourceTrigger=PropertyChanged}"
                                          ToolTip="Show this seat's corner tile as a plain colour instead of a live preview -- e.g. for a cloaky alt you don't want visible even as a thumbnail."/>
                                <StackPanel Orientation="Horizontal" Margin="4,4,4,2">
                                  <TextBlock Text="Alias" FontSize="10" VerticalAlignment="Center"
                                             Foreground="{StaticResource MutedBrush}"/>
                                  <TextBox Text="{Binding LabelAlias, UpdateSourceTrigger=PropertyChanged}"
                                           Width="110" Padding="4,2" FontSize="10" Margin="4,0,0,0"
                                           ToolTip="Show this text on the preview label instead of the character name. Blank = use the real name. Cosmetic only - window matching still uses the real name."/>
                                </StackPanel>
                              </StackPanel>
                            </Grid>
                          </Border>


                        </StackPanel>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>
              </Border>
            </Grid>
          </Grid>
        </TabItem>

        <!-- ──────────────────── LAYOUTS TAB ──────────────────── -->
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8A9;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center"/>
              <TextBlock Text="Layouts" VerticalAlignment="Center"/>
            </StackPanel>
          </TabItem.Header>
          <Grid Margin="12">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Margin="0,0,0,10">
              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Apply Profile" Command="{Binding ApplyProfileCommand}" Style="{StaticResource AccentButton}"/>
                <Button Content="Undo Last Apply" Command="{Binding UndoLastApplyCommand}" ToolTip="Restore windows to positions they held before the last layout apply"/>
                <Button Content="Capture Current" Command="{Binding CaptureProfileCommand}"/>
                <Button Content="Save" Command="{Binding SaveCommand}"/>
              </StackPanel>
              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Layouts" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="A layout is the on-screen grid your clients snap into. Choose one and click Apply Profile. Built-in presets can't be edited — Duplicate one (or Capture Current to save your current window positions) to make your own."
                           Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,3,0,0" TextWrapping="Wrap"/>
              </StackPanel>
            </DockPanel>

            <Grid Grid.Row="1">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <!-- Profile list -->
              <Border Background="{StaticResource PanelBrush}"
                      BorderBrush="{StaticResource BorderBrush}"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="10">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <!-- 2d: Profile search filter -->
                  <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="Profiles" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding ProfileSearchText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,4" FontSize="12"
                             ToolTip="Filter profiles by name"/>
                  </StackPanel>
                  <ListBox Grid.Row="1" ItemsSource="{Binding ProfilesView}"
                           SelectedItem="{Binding SelectedProfile}"
                           DisplayMemberPath="Name">
                    <ListBox.GroupStyle>
                      <GroupStyle>
                        <GroupStyle.ContainerStyle>
                          <Style TargetType="GroupItem">
                            <Setter Property="Template">
                              <Setter.Value>
                                <ControlTemplate TargetType="GroupItem">
                                  <StackPanel>
                                    <ToggleButton x:Name="toggle" IsChecked="True"
                                                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                                  Padding="6,5" Margin="0,2,0,0">
                                      <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                          <Border x:Name="bd" Background="#0E1520" Padding="{TemplateBinding Padding}">
                                            <DockPanel>
                                              <TextBlock x:Name="arrow" DockPanel.Dock="Right"
                                                         Text="▲" FontSize="8" Margin="4,0,2,0"
                                                         Foreground="{StaticResource MutedBrush}"
                                                         VerticalAlignment="Center"/>
                                              <ContentPresenter VerticalAlignment="Center"/>
                                            </DockPanel>
                                          </Border>
                                          <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="False">
                                              <Setter TargetName="arrow" Property="Text" Value="▼"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                              <Setter TargetName="bd" Property="Background" Value="#131D2D"/>
                                            </Trigger>
                                          </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                      </ToggleButton.Template>
                                      <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="11"
                                                 Foreground="{StaticResource MutedBrush}"/>
                                    </ToggleButton>
                                    <ItemsPresenter x:Name="items"/>
                                  </StackPanel>
                                  <ControlTemplate.Triggers>
                                    <Trigger SourceName="toggle" Property="IsChecked" Value="False">
                                      <Setter TargetName="items" Property="Visibility" Value="Collapsed"/>
                                    </Trigger>
                                  </ControlTemplate.Triggers>
                                </ControlTemplate>
                              </Setter.Value>
                            </Setter>
                          </Style>
                        </GroupStyle.ContainerStyle>
                      </GroupStyle>
                    </ListBox.GroupStyle>
                  </ListBox>
                  <WrapPanel Grid.Row="2" Margin="0,8,0,0">
                    <Button Content="Auto-select" Command="{Binding AutoSelectBestProfileCommand}"
                            ToolTip="Pick the best built-in profile for your current slot count and target monitor (prefers Center Master for 4-15 accounts)."/>
                    <Button Content="New" Command="{Binding NewProfileCommand}"/>
                    <Button Content="Edit on Monitor" Command="{Binding EditLayoutCommand}"
                            ToolTip="Open a full-screen editor on the target monitor: drag slots to move them, drag edges to resize, add or remove slots. Editing a built-in preset saves a custom copy."/>
                    <Button Content="Duplicate" Command="{Binding DuplicateProfileCommand}"/>
                    <Button Content="Delete" Command="{Binding DeleteProfileCommand}" Style="{StaticResource DangerButton}"/>
                    <Button Content="Import" Command="{Binding ImportProfileCommand}"/>
                    <Button Content="Export" Command="{Binding ExportProfileCommand}"/>
                  </WrapPanel>
                </Grid>
              </Border>

              <!-- Profile detail -->
              <Border Grid.Column="2"
                      Background="{StaticResource PanelBrush}"
                      BorderBrush="{StaticResource BorderBrush}"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="10">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                  </Grid.RowDefinitions>

                  <!-- Profile settings row -->
                  <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                      <TextBlock Text="Active Profile" FontSize="15" FontWeight="SemiBold"/>
                      <TextBox Text="{Binding SelectedProfile.Name, UpdateSourceTrigger=PropertyChanged}"
                               IsReadOnly="{Binding SelectedProfileIsBuiltIn}"
                               Margin="0,6,8,0"
                               ToolTip="Profile name"/>
                      <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Target monitor" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding Monitors}"
                                  SelectedValue="{Binding LayoutTargetMonitorId}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="Summary"
                                  Width="340"
                                  Margin="8,0,0,0"/>
                        <CheckBox Content="Avoid taskbar (this profile)"
                                  IsChecked="{Binding SelectedProfileAvoidTaskbar}"
                                  ToolTip="Fit this profile into the monitor work area so the bottom row clears the Windows taskbar. Saved per profile."
                                  Margin="10,0,0,0"/>
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <StackPanel.Style>
                          <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding SelectedProfileIsFamilyTemplate}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Resolution" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding AvailableFamilyResolutions}"
                                  SelectedItem="{Binding SelectedFamilyResolution}"
                                  DisplayMemberPath="Label"
                                  Width="120" Margin="8,0,10,0"
                                  ToolTip="Monitor resolution this Grid/Center Master layout is built for."/>
                        <TextBlock Text="Accounts" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding AvailableFamilyCounts}"
                                  SelectedItem="{Binding SelectedFamilyCount}"
                                  Width="70" Margin="8,0,0,0"
                                  ToolTip="Number of accounts this layout arranges."/>
                        <StackPanel Orientation="Horizontal">
                          <StackPanel.Style>
                            <Style TargetType="StackPanel">
                              <Setter Property="Visibility" Value="Collapsed"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedProfileHasFamilySide}" Value="True">
                                  <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </StackPanel.Style>
                          <TextBlock Text="Side" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                          <ComboBox ItemsSource="{Binding AvailableFamilySides}"
                                    SelectedItem="{Binding SelectedFamilySide}"
                                    Width="90" Margin="8,0,0,0"
                                    ToolTip="Which edge of the monitor the preview stack sits on."/>
                        </StackPanel>
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Master resolution" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"
                                   ToolTip="Override where EveDeck places the master window. Match this to EVE's Fixed Window resolution when using AMD VSR or Nvidia DSR. Auto = fill the target monitor."/>
                        <ComboBox ItemsSource="{Binding AvailableMasterResolutions}"
                                  SelectedItem="{Binding SelectedMasterResolution}"
                                  DisplayMemberPath="Label"
                                  Width="180" Margin="8,0,8,0"
                                  ToolTip="Available display modes. Resolutions above native require AMD VSR or Nvidia DSR — see the guide below."/>
                        <Button Content="Set" Command="{Binding SetMasterResolutionCommand}" Padding="8,3"
                                ToolTip="Save this resolution override to the active profile"/>
                        <Button Content="Auto" Command="{Binding ClearMasterResolutionCommand}" Padding="8,3" Margin="4,0,10,0"
                                ToolTip="Clear the override — master slot scales to fill the monitor as usual"/>
                        <TextBlock Text="{Binding MasterResolutionStatus}" FontSize="11" VerticalAlignment="Center">
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding MasterResolutionStatusSeverity}" Value="active">
                                  <Setter Property="Foreground" Value="#22C55E"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding MasterResolutionStatusSeverity}" Value="warn">
                                  <Setter Property="Foreground" Value="#F59E0B"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                      </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                      <TextBlock Text="Built-in preset" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Right" FontSize="11">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding SelectedProfileIsBuiltIn}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                      <CheckBox Content="Use physical pixels" IsChecked="{Binding UsePhysicalPixels}"/>
                    </StackPanel>
                  </Grid>

                  <!-- Layout preview -->
                  <Border Grid.Row="1"
                          Background="#0E1520"
                          BorderBrush="{StaticResource BorderBrush}"
                          BorderThickness="1"
                          CornerRadius="4"
                          Padding="10"
                          Margin="0,0,0,8">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <Canvas Width="320" Height="200" ClipToBounds="True">
                        <ItemsControl ItemsSource="{Binding LayoutPreviewSlots}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <Canvas/>
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                              <Setter Property="Canvas.Left" Value="{Binding X}"/>
                              <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                            </Style>
                          </ItemsControl.ItemContainerStyle>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Width="{Binding Width}" Height="{Binding Height}"
                                      Background="#172A45"
                                      BorderBrush="{StaticResource AccentBrush}"
                                      BorderThickness="1"
                                      CornerRadius="2"
                                      Opacity="0.9">
                                <TextBlock Text="{Binding DisplayText}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="11"/>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </Canvas>
                      <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Layout Preview" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Text="Scaled preview of slot positions. See the table below for exact coordinates."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                      </StackPanel>
                    </Grid>
                  </Border>

                  <!-- Slot table -->
                  <DataGrid Grid.Row="2" ItemsSource="{Binding ActiveProfileSlots}" IsReadOnly="{Binding SelectedProfileIsBuiltIn}">
                    <DataGrid.Columns>
                      <DataGridTextColumn Header="Slot" Binding="{Binding SlotNumber}" Width="55"/>
                      <DataGridTextColumn Header="Label" Binding="{Binding Label, UpdateSourceTrigger=PropertyChanged}" Width="130"/>
                      <DataGridTextColumn Header="Monitor" Binding="{Binding MonitorId, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                      <DataGridTextColumn Header="X" Binding="{Binding X, UpdateSourceTrigger=PropertyChanged}" Width="75"/>
                      <DataGridTextColumn Header="Y" Binding="{Binding Y, UpdateSourceTrigger=PropertyChanged}" Width="75"/>
                      <DataGridTextColumn Header="Width" Binding="{Binding Width, UpdateSourceTrigger=PropertyChanged}" Width="85"/>
                      <DataGridTextColumn Header="Height" Binding="{Binding Height, UpdateSourceTrigger=PropertyChanged}" Width="85"/>
                      <DataGridCheckBoxColumn Header="Borderless" Binding="{Binding Borderless}" Width="90"/>
                    </DataGrid.Columns>
                  </DataGrid>
                </Grid>
              </Border>
            </Grid>

            <!-- ── VSR / DSR Setup Guide (collapsed by default) ── -->
            <Expander Grid.Row="2" Header="VSR / DSR Setup Guide" Margin="0,8,0,0">
              <ScrollViewer MaxHeight="360" Margin="0,8,0,0" Padding="0,0,12,0">
                <StackPanel>
                  <TextBlock TextWrapping="Wrap" LineHeight="22" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,16">
Both AMD and Nvidia let you set a virtual resolution higher than your panel's native pixels, then downscale on output -- giving EVE a larger canvas to render into. Enable VSR or DSR first, set your desktop to the virtual resolution, match it in EVE's Fixed Window settings, then pick it above with Master resolution and click Set.
                  </TextBlock>
                  <TextBlock Text="AMD Virtual Super Resolution (VSR)" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                  <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="24"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="1." Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" TextWrapping="Wrap" LineHeight="22" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6">Open AMD Software: Adrenalin Edition. Go to <Run Foreground="{StaticResource TextBrush}">Display</Run>, find <Run Foreground="{StaticResource TextBrush}">Virtual Super Resolution</Run>, and toggle it <Run Foreground="{StaticResource TextBrush}">On</Run>.</TextBlock>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="2." Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" LineHeight="22" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6">Open <Run Foreground="{StaticResource TextBrush}">Windows Settings &gt; System &gt; Display &gt; Display resolution</Run>. You will now see resolutions higher than your panel's native size. Select the one you want.</TextBlock>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="3." Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" LineHeight="22" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6">In EVE: <Run Foreground="{StaticResource TextBrush}">ESC &gt; Display &amp; Graphics &gt; Window Mode: Fixed Window &gt; Resolution</Run> -- set it to match. All clients must share the same Fixed Window size.</TextBlock>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="4." Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" LineHeight="22" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6">Restart all EVE clients. Use the Master resolution picker above, click Set, then Apply Profile.</TextBlock>
                  </Grid>
                  <TextBlock Text="Nvidia Dynamic Super Resolution (DSR)" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                  <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="24"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="1." Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" TextWrapping="Wrap" LineHeight="22" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6">Open <Run Foreground="{StaticResource TextBrush}">Nvidia Control Panel &gt; Manage 3D Settings &gt; DSR - Factors</Run>. Enable the multipliers you want (e.g. 2.00x for 4K on a 1440p panel).</TextBlock>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="2." Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" LineHeight="22" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6">Open <Run Foreground="{StaticResource TextBrush}">Windows Settings &gt; System &gt; Display &gt; Display resolution</Run> and select the new virtual resolution.</TextBlock>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="3." Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" LineHeight="22" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6">In EVE: <Run Foreground="{StaticResource TextBrush}">ESC &gt; Display &amp; Graphics &gt; Window Mode: Fixed Window &gt; Resolution</Run> -- set to match. All clients must share the same Fixed Window size.</TextBlock>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="4." Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" LineHeight="22" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6">Restart all EVE clients and reapply your EveDeck layout.</TextBlock>
                  </Grid>
                  <TextBlock Text="Things to know" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                  <Border Background="#1A1E14" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                    <TextBlock TextWrapping="Wrap" LineHeight="22" Foreground="{StaticResource MutedBrush}"><Run Foreground="#C8E870" FontWeight="SemiBold">GPU cost scales with client count.</Run> Every running EVE client renders at the virtual resolution. On a 5-client setup, switching from 1920x1065 to 3840x2160 quadruples pixel work per client. Check GPU utilisation before committing.</TextBlock>
                  </Border>
                  <Border Background="#1A1018" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                    <TextBlock TextWrapping="Wrap" LineHeight="22" Foreground="{StaticResource MutedBrush}"><Run Foreground="#E870C8" FontWeight="SemiBold">5210x1440 is not VSR.</Run> That is AMD Eyefinity -- a multi-monitor super-wide desktop. Do not select it unless you have two physical monitors combined in Eyefinity.</TextBlock>
                  </Border>
                  <Border Background="#0E1520" CornerRadius="4" Padding="10,8">
                    <TextBlock TextWrapping="Wrap" LineHeight="22" Foreground="{StaticResource MutedBrush}"><Run Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold">EveDeck profiles are resolution-independent.</Run> Layout slots are stored as fractional rects and scale automatically to whatever resolution your clients run at.</TextBlock>
                  </Border>
                </StackPanel>
              </ScrollViewer>
            </Expander>
          </Grid>
        </TabItem>

        <!-- ──────────────────── HOTKEYS TAB ──────────────────── -->
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE765;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center"/>
              <TextBlock Text="Hotkeys" VerticalAlignment="Center"/>
            </StackPanel>
          </TabItem.Header>
          <Grid Margin="12">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Margin="0,0,0,10">
              <Button DockPanel.Dock="Right" Content="Reset to Defaults"
                      Command="{Binding ResetHotkeysCommand}"
                      Style="{StaticResource DangerButton}"
                      ToolTip="Reset all hotkey bindings to factory defaults"/>
              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Hotkeys" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="Global shortcuts for switching clients and applying layouts. Click Set on a row, press the key combo you want (Esc cancels), and the row highlights while it listens. Tick the On box to enable a shortcut."
                           Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,3,0,0" TextWrapping="Wrap"/>
                <TextBlock Text="Tip: see Options → Hotkey Behavior to control whether hotkeys fire while EVE isn't the active window."
                           Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,3,0,0" TextWrapping="Wrap"/>
              </StackPanel>
            </DockPanel>

            <DataGrid x:Name="HotkeyDataGrid"
                      Grid.Row="1"
                      ItemsSource="{Binding Hotkeys}"
                      SelectedItem="{Binding SelectedHotkey}"
                      IsReadOnly="True"
                      EnableRowVirtualization="False">
              <!-- Capture row highlight -->
              <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                      <Setter Property="Background" Value="#0E2040"/>
                      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                      <Setter Property="BorderThickness" Value="0,1,0,1"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </DataGrid.RowStyle>
              <DataGrid.Columns>
                <DataGridTemplateColumn Header="On" Width="55">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <CheckBox IsChecked="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Group" Binding="{Binding Category}" IsReadOnly="True" Width="130"/>
                <DataGridTextColumn Header="Action" Binding="{Binding DisplayName}" IsReadOnly="True" Width="2*"/>
                <!-- Template (not Text) column so a capturing row can say so explicitly: the row
                     highlight alone never told the user the app was waiting for a keypress. -->
                <DataGridTemplateColumn Header="Key Combo" Width="185">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="{Binding DisplayGesture}"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                                <Setter Property="Text" Value="Press a key combo... (Esc cancels)"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="FontStyle" Value="Italic"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Character" Width="170">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <ComboBox Style="{StaticResource CharacterPickerCombo}"
                                ItemsSource="{Binding DataContext.CharacterIdentities, RelativeSource={RelativeSource AncestorType=Window}}"
                                TextSearch.TextPath="Name"
                                Text="{Binding TargetCharacter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Visibility="{Binding IsCharacterSwitch, Converter={StaticResource BoolToVis}}"
                                ToolTip="Which character this hotkey brings forward. Pick from the list or type a name. Follows the character across master swaps.">
                        <ComboBox.ItemTemplate>
                          <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                              <Ellipse Width="18" Height="18" Margin="0,0,6,0" VerticalAlignment="Center" Style="{StaticResource PortraitDot}"
                                       Visibility="{Binding HasPortrait, Converter={StaticResource BoolToVis}}">
                                <Ellipse.Fill>
                                  <ImageBrush ImageSource="{Binding Portrait.Image}" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                              </Ellipse>
                              <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                            </StackPanel>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Edit" Width="160">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal">
                        <Button Content="Set"
                                Command="{Binding DataContext.CaptureHotkeyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Padding="8,4"/>
                        <Button Content="Clear"
                                Command="{Binding DataContext.ClearHotkeyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Padding="8,4"/>
                      </StackPanel>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </TabItem>

        <!-- ──────────────────── OPTIONS TAB ──────────────────── -->
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center"/>
              <TextBlock Text="Options" VerticalAlignment="Center"/>
            </StackPanel>
          </TabItem.Header>
          <Grid Margin="16">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
              <TextBlock Text="Options" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,2"/>
              <TextBlock Text="Visual and behavior settings. Changes apply immediately and are saved automatically."
                         Foreground="{StaticResource MutedBrush}" FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>

            <Grid Grid.Row="1">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                      BorderThickness="1" CornerRadius="6" Padding="6">
                <ListBox x:Name="OptionsMenu" SelectedIndex="0" BorderThickness="0" Background="Transparent">
                  <ListBoxItem Content="Character Names"/>
                  <ListBoxItem Content="Visual Effects"/>
                  <ListBoxItem Content="Startup"/>
                  <ListBoxItem Content="Window Behavior"/>
                  <ListBoxItem Content="System Integration"/>
                  <ListBoxItem Content="Interface Scale"/>
                  <ListBoxItem Content="Setup"/>
                  <ListBoxItem Content="Previews"/>
                  <ListBoxItem Content="Settings Backup"/>
                  <ListBoxItem Content="Hotkey Behavior"/>
                  <ListBoxItem Content="Performance"/>
                  <ListBoxItem Content="EVE Launcher"/>
                  <ListBoxItem Content="Game Event Alerts"/>
                  <ListBoxItem Content="Overlay Allow List"/>
                  <ListBoxItem Content="Notifications"/>
                  <ListBoxItem Content="Comms"/>
                  <ListBoxItem Content="Config Profiles"/>
                </ListBox>
              </Border>

              <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
                <Grid MaxWidth="700" HorizontalAlignment="Left">
                  <!-- section 0: Character Names -->
                  <StackPanel Visibility="{Binding SelectedIndex, ElementName=OptionsMenu, Converter={StaticResource IndexToVisibility}, ConverterParameter=0}">
                    <TextBlock Text="Character Names" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
              <TextBlock TextWrapping="Wrap" LineHeight="20" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,14">
Auto-filled from the EVE window title when a client is assigned — "EVE - Name" becomes "Name". Edit here to rename any slot.
              </TextBlock>
              <ItemsControl ItemsSource="{Binding Assignments}" Margin="0,0,0,4">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <DockPanel Margin="0,4">
                      <Border Width="28" Height="28" CornerRadius="14" VerticalAlignment="Center"
                              DockPanel.Dock="Left" Margin="0,0,10,0">
                        <Border.Style>
                          <Style TargetType="Border">
                            <Setter Property="Background" Value="#242D3E"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsAssigned}" Value="True">
                                <Setter Property="Background" Value="#163527"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding SlotNumber}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontWeight="Bold" FontSize="11">
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAssigned}" Value="True">
                                  <Setter Property="Foreground" Value="#22C55E"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                      </Border>
                      <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                               Padding="6,4" FontSize="13"
                               ToolTip="Character name shown on this slot"/>
                    </DockPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
                  </StackPanel>
                  <!-- section 1: Visual Effects -->
                  <StackPanel Visibility="{Binding SelectedIndex, ElementName=OptionsMenu, Converter={StaticResource IndexToVisibility}, ConverterParameter=1}">
                    <TextBlock Text="Visual Effects" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
              <TextBlock TextWrapping="Wrap" LineHeight="20" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,14">
Styling for the active-client highlight frame and the preview-label pills (font, style, opacity). Per-seat overrides live behind the "Style..." button on each slot below.
              </TextBlock>

              <TextBlock Text="Active frame" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
              <CheckBox Content="Enable active client frame"
                        IsChecked="{Binding ActiveFrameEnabled}"
                        ToolTip="Draws a soft glowing, click-through outline around whichever EVE client you're currently using."
                        Margin="0,0,0,10"/>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                <TextBlock Text="Thickness" VerticalAlignment="Center" Width="80" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <Slider Minimum="1" Maximum="20" Value="{Binding ActiveFrameThickness}" Width="150" VerticalAlignment="Center"
                        IsSnapToTickEnabled="True" TickFrequency="1"/>
                <TextBlock Text="{Binding ActiveFrameThickness, StringFormat={}{0}px}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                <TextBlock Text="Glow radius" VerticalAlignment="Center" Width="80" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <Slider Minimum="1" Maximum="40" Value="{Binding ActiveFrameGlowRadius}" Width="150" VerticalAlignment="Center"
                        IsSnapToTickEnabled="True" TickFrequency="1"/>
                <TextBlock Text="{Binding ActiveFrameGlowRadius, StringFormat={}{0}px}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,16" VerticalAlignment="Center">
                <TextBlock Text="Color" VerticalAlignment="Center" Width="80" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <Border Width="24" Height="24" Margin="0,0,8,0" CornerRadius="4"
                        Background="{Binding ActiveFrameBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                <Button Content="Pick Color..." Click="FrameColorPick_Click" Padding="6,3" Margin="0,0,8,0" FontSize="11"/>
                <Button Content="Amber" Tag="#F59E0B" Click="FrameColorPreset_Click" Padding="6,3" FontSize="11" Margin="0,0,4,0"/>
                <Button Content="Cyan"  Tag="#22D3EE" Click="FrameColorPreset_Click" Padding="6,3" FontSize="11" Margin="0,0,4,0"/>
                <Button Content="Green" Tag="#22C55E" Click="FrameColorPreset_Click" Padding="6,3" FontSize="11" Margin="0,0,4,0"/>
                <Button Content="Red"   Tag="#EF4444" Click="FrameColorPreset_Click" Padding="6,3" FontSize="11" Margin="0,0,4,0"/>
                <Button Content="White" Tag="#FFFFFF"  Click="FrameColorPreset_Click" Padding="6,3" FontSize="11" Margin="0,0,4,0"/>
                <Button Content="Blue"  Tag="#3B82F6" Click="FrameColorPreset_Click" Padding="6,3" FontSize="11"/>
              </StackPanel>

              <TextBlock Text="Preview label — normal" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                <TextBlock Text="Style" VerticalAlignment="Center" Width="80" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <ComboBox Width="170" SelectedValuePath="Tag" FontSize="11"
                          SelectedValue="{Binding CornerOverlayLabelStyle}"
                          ToolTip="Pill = a name chip over the tile. Icon+name = character portrait beside plain text.">
                  <ComboBoxItem Tag="Pill" Content="Pill (name chip)"/>
                  <ComboBoxItem Tag="IconText" Content="Character icon + name"/>
                </ComboBox>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                <TextBlock Text="Font" VerticalAlignment="Center" Width="80" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <Button Content="Choose font..." Click="LabelFontPick_Click" Padding="6,3" Margin="0,0,8,0" FontSize="11"/>
                <TextBlock Text="{Binding LabelFontSummary}" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                <TextBlock Text="Style" VerticalAlignment="Center" Width="80" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <CheckBox Content="Bold" IsChecked="{Binding LabelBold}" Margin="0,0,10,0" FontSize="11"/>
                <CheckBox Content="Italic" IsChecked="{Binding LabelItalic}" Margin="0,0,10,0" FontSize="11"/>
                <CheckBox Content="Drop shadow" IsChecked="{Binding LabelDropShadow}" Margin="0,0,10,0" FontSize="11"/>
                <CheckBox Content="Outline" IsChecked="{Binding LabelOutline}" FontSize="11"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,16" VerticalAlignment="Center">
                <TextBlock Text="Opacity" VerticalAlignment="Center" Width="80" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <Slider Minimum="20" Maximum="100" Value="{Binding LabelOpacity}" Width="150" VerticalAlignment="Center"
                        IsSnapToTickEnabled="True" TickFrequency="5"/>
                <TextBlock Text="{Binding LabelOpacity, StringFormat={}{0}%}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11"/>
              </StackPanel>

              <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Preview label — MASTER" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                <Button Content="&#8635; Reset to normal" Click="MasterLabelStyleAndFontReset_Click" Padding="5,1" Margin="10,0,0,0" MinHeight="0" FontSize="10"
                        ToolTip="Reset the MASTER font, style and opacity overrides so they inherit the normal label settings above"/>
              </StackPanel>
              <TextBlock Text="Falls back to the normal label settings above until you customize it here." Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="0,0,0,8"/>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                <TextBlock Text="Font" VerticalAlignment="Center" Width="80" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <Button Content="Choose font..." Click="MasterLabelFontPick_Click" Padding="6,3" Margin="0,0,8,0" FontSize="11"/>
                <TextBlock Text="{Binding MasterLabelFontSummary}" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                <TextBlock Text="Style" VerticalAlignment="Center" Width="80" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <CheckBox Content="Bold" IsChecked="{Binding MasterLabelBold}" Margin="0,0,10,0" FontSize="11"/>
                <CheckBox Content="Italic" IsChecked="{Binding MasterLabelItalic}" Margin="0,0,10,0" FontSize="11"/>
                <CheckBox Content="Drop shadow" IsChecked="{Binding MasterLabelDropShadow}" Margin="0,0,10,0" FontSize="11"/>
                <CheckBox Content="Outline" IsChecked="{Binding MasterLabelOutline}" FontSize="11"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                <TextBlock Text="Opacity" VerticalAlignment="Center" Width="80" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <Slider Minimum="20" Maximum="100" Value="{Binding MasterLabelOpacity}" Width="150" VerticalAlignment="Center"
                        IsSnapToTickEnabled="True" TickFrequency="5"/>
                <TextBlock Text="{Binding MasterLabelOpacity, StringFormat={}{0}%}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11"/>
              </StackPanel>

              <TextBlock Text="Preview tiles" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,16" VerticalAlignment="Center">
                <TextBlock Text="Opacity" VerticalAlignment="Center" Width="80" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <Slider Minimum="10" Maximum="100" Value="{Binding PreviewOpacity}" Width="150" VerticalAlignment="Center"
                        IsSnapToTickEnabled="True" TickFrequency="5"
                        ToolTip="Transparency of every DWM preview thumbnail, corners and the master rect alike."/>
                <TextBlock Text="{Binding PreviewOpacity, StringFormat={}{0}%}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11"/>
              </StackPanel>
                  </StackPanel>
                  <!-- section 2: Startup -->
                  <StackPanel Visibility="{Binding SelectedIndex, ElementName=OptionsMenu, Converter={StaticResource IndexToVisibility}, ConverterParameter=2}">
                    <TextBlock Text="Startup" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
              <CheckBox Content="Apply a layout profile on startup"
                        IsChecked="{Binding ApplyProfileOnStartup}"
                        Margin="0,0,0,10"/>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Profile" VerticalAlignment="Center" Width="80" Foreground="{StaticResource MutedBrush}"/>
                <ComboBox ItemsSource="{Binding Profiles}"
                          SelectedValue="{Binding StartupProfileId}"
                          SelectedValuePath="Id"
                          DisplayMemberPath="Name"
                          Width="340"/>
              </StackPanel>
              <CheckBox Content="Re-apply active profile when clients are (re)launched"
                        IsChecked="{Binding AutoApplyOnClientLaunch}"
                        Margin="0,0,0,4"/>
              <TextBlock Text="Remembers your layout: close all clients and open them again and they snap back into place automatically (requires Auto-refresh)."
                         Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,4"/>
                  </StackPanel>
                  <!-- section 3: Window Behavior -->
                  <StackPanel Visibility="{Binding SelectedIndex, ElementName=OptionsMenu, Converter={StaticResource IndexToVisibility}, ConverterParameter=3}">
                    <TextBlock Text="Window Behavior" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
              <CheckBox Content="Minimize to system tray instead of taskbar"
                        IsChecked="{Binding MinimizeToTray}"
                        Margin="0,0,0,10"/>
                  </StackPanel>
                  <!-- section 4: System Integration -->
                  <StackPanel Visibility="{Binding SelectedIndex, ElementName=OptionsMenu, Converter={StaticResource IndexToVisibility}, ConverterParameter=4}">
                    <TextBlock Text="System Integration" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
              <CheckBox Content="Launch EveDeck with Windows"
                        IsChecked="{Binding LaunchWithWindows}"
                        Visibility="{Binding CanManageLaunchWithWindows, Converter={StaticResource BoolToVisibility}}"
                        Margin="0,0,0,6"/>
              <TextBlock Text="Starts EveDeck automatically when you sign in to Windows."
                         Visibility="{Binding CanManageLaunchWithWindows, Converter={StaticResource BoolToVisibility}}"
                         Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,4"/>
              <TextBlock TextWrapping="Wrap" LineHeight="18" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,4"
                         Visibility="{Binding CanManageLaunchWithWindows, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
                This is the Microsoft Store version, so Windows manages startup for you: open Settings &gt; Apps &gt; Startup and turn on EveDeck there.
              </TextBlock>
                  </StackPanel>
                  <!-- section 5: Interface Scale -->
                  <StackPanel Visibility="{Binding SelectedIndex, ElementName=OptionsMenu, Converter={StaticResource IndexToVisibility}, ConverterParameter=5}">
                    <TextBlock Text="Interface Scale" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
              <TextBlock TextWrapping="Wrap" LineHeight="20" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,14">
Scales the entire EveDeck interface up or down. Useful on 4K displays running at 100% Windows scaling where the UI would otherwise appear small.
              </TextBlock>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,4" VerticalAlignment="Center">
                <TextBlock Text="Scale" VerticalAlignment="Center" Width="80" Foreground="{StaticResource MutedBrush}"/>
                <ComboBox x:Name="UiScaleComboBox" Width="120" SelectionChanged="UiScaleComboBox_SelectionChanged">
                  <ComboBoxItem Content="50%"  Tag="0.5"/>
                  <ComboBoxItem Content="75%"  Tag="0.75"/>
                  <ComboBoxItem Content="100%" Tag="1.0"/>
                  <ComboBoxItem Content="125%" Tag="1.25"/>
                  <ComboBoxItem Content="150%" Tag="1.5"/>
                  <ComboBoxItem Content="175%" Tag="1.75"/>
                  <ComboBoxItem Content="200%" Tag="2.0"/>
                  <ComboBoxItem Content="250%" Tag="2.5"/>
                  <ComboBoxItem Content="300%" Tag="3.0"/>
                </ComboBox>
              </StackPanel>
                  </StackPanel>
                  <!-- section 6: Setup -->
                  <StackPanel Visibility="{Binding SelectedIndex, ElementName=OptionsMenu, Converter={StaticResource IndexToVisibility}, ConverterParameter=6}">
                    <TextBlock Text="Setup" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
              <TextBlock TextWrapping="Wrap" LineHeight="20" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,8">
Re-run the guided setup to pick your client count and target monitor and apply a matching layout.
              </TextBlock>
              <Button Content="Run setup wizard" Click="RunSetupWizard_Click"
                      HorizontalAlignment="Left" MinWidth="150" Margin="0,0,0,4"/>
                  </StackPanel>
                  <!-- section 7: Previews -->
                  <StackPanel Visibility="{Binding SelectedIndex, ElementName=OptionsMenu, Converter={StaticResource IndexToVisibility}, ConverterParameter=7}">
                    <TextBlock Text="Previews" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
              <TextBlock TextWrapping="Wrap" LineHeight="20" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,14">
Shows your background clients as live mini-previews in the screen corners while the master client fills the center. The previews are real-time video of each client, so you can keep an eye on all of them at once. Switching between clients is instant because the windows don't actually move or resize.
              </TextBlock>
              <CheckBox Content="Enable live previews"
                        IsChecked="{Binding CornerOverlaysEnabled}"
                        Margin="0,0,0,10"/>
              <CheckBox Content="Click a preview to bring that client to the center"
                        IsChecked="{Binding FocusPreviewOnClick}"
                        Margin="0,0,0,2"/>
              <TextBlock TextWrapping="Wrap" LineHeight="18" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,10">
Can't read a capacitor or HUD in a preview? A preview shows the whole client shrunk into the tile, so a 2560-wide client in a 320-wide tile is an 8x reduction. Three things actually help, in order of effect: raise UI Scaling inside EVE itself on your alt clients (Esc &gt; Display &amp; Graphics) so the HUD is physically bigger in the source; make that tile larger; and raise the hover zoom for that seat. Preview opacity below 100% also washes detail out.

EveDeck will not crop a preview down to just the HUD -- showing only part of a client is against the EULA, so scaling the whole window is the supported route.
              </TextBlock>
              <TextBlock Text="Clicking a preview switches focus to that client — the same as the center-seat hotkey. The click only moves windows; it is never sent into the EVE client."
                         TextWrapping="Wrap" FontSize="11" Margin="20,0,0,10"
                         Foreground="{StaticResource MutedBrush}"/>
              <CheckBox Content="Hover a preview to peek at that client over the master"
                        IsChecked="{Binding HoverPreviewEnabled}"
                        Margin="0,0,0,2"/>
              <TextBlock Text="Moving your mouse over a preview temporarily raises that client over the master so you can see it at a glance. It returns to its parked position when you move away."
                         TextWrapping="Wrap" FontSize="11" Margin="20,0,0,6"
                         Foreground="{StaticResource MutedBrush}"/>
              <StackPanel Orientation="Horizontal" Margin="20,0,0,4" VerticalAlignment="Center"
                          IsEnabled="{Binding HoverPreviewEnabled}">
                <TextBlock Text="Hover style" VerticalAlignment="Center" Width="80" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <ComboBox Width="220" SelectedValuePath="Tag" FontSize="11"
                          SelectedValue="{Binding HoverPreviewStyle}">
                  <ComboBoxItem Tag="Peek" Content="Peek (raise the real client over the master)"/>
                  <ComboBoxItem Tag="Zoom" Content="Zoom (magnify just the preview in place)"/>
                </ComboBox>
                <TextBlock Text="Zoom" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="10,0,4,0"/>
                <TextBox Width="36"
                         Text="{Binding HoverZoomFactor, UpdateSourceTrigger=PropertyChanged}"
                         HorizontalContentAlignment="Center" FontSize="11"
                         ToolTip="Preview magnification for the Zoom style (1.5-8). Individual seats can override this on their slot card in the Clients tab."/>
                <TextBlock Text="x" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="2,0,0,0"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="20,0,0,10" VerticalAlignment="Center"
                          IsEnabled="{Binding HoverPreviewEnabled}">
                <TextBlock Text="Peek delay" VerticalAlignment="Center" Width="80" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <TextBox Width="48"
                         Text="{Binding HoverPreviewDelayMs, UpdateSourceTrigger=PropertyChanged}"
                         HorizontalContentAlignment="Center" FontSize="11"/>
                <TextBlock Text="ms  (0 = instant, default 250)" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="6,0,0,0"/>
              </StackPanel>
              <CheckBox Content="Show character name pills"
                        IsChecked="{Binding CornerOverlayShowLabel}"
                        Margin="0,0,0,6"/>
              <CheckBox Content="Prefix pills with position code (e.g. TL · Name)"
                        IsChecked="{Binding CornerOverlayShowSlotNumber}"
                        Margin="0,0,0,6"/>
              <CheckBox Content="Show current solar system on pills (from Local chat logs)"
                        IsChecked="{Binding CornerOverlayShowSystem}"
                        Margin="0,0,0,6"/>
              <CheckBox Content="Hide a preview tile while that client is the active window"
                        IsChecked="{Binding HideActiveSeatTile}"
                        ToolTip="The active client is already on screen full-size; hiding its own tile reduces clutter"
                        Margin="0,0,0,6"/>
              <TextBlock Text="Tip: to hide one seat's preview permanently, use its &quot;Hide preview&quot; box on the Clients tab."
                         Foreground="{StaticResource MutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>

              <CheckBox Content="Hide a preview tile while that client is still on the login screen"
                        IsChecked="{Binding HidePreviewsAtLoginScreen}"
                        ToolTip="A client that hasn't picked a character yet shows nothing useful in its thumbnail. Detected from the window title only."
                        Margin="0,0,0,6"/>

              <CheckBox Content="Hide all previews while EVE isn't the active app"
                        IsChecked="{Binding HidePreviewsOnFocusLoss}"
                        ToolTip="Alt-tab to a browser, Discord or a spreadsheet and the previews get out of the way; switch back to EVE and they return. Nothing is torn down, so coming back is instant."
                        Margin="0,0,0,6"/>
              <StackPanel Orientation="Horizontal" Margin="16,0,0,10" VerticalAlignment="Center">
                <TextBlock Text="after" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <TextBox Width="48" Margin="6,0,0,0"
                         Text="{Binding HidePreviewsOnFocusLossDelaySeconds, UpdateSourceTrigger=PropertyChanged}"
                         HorizontalContentAlignment="Center" FontSize="11"/>
                <TextBlock Text="sec (0 = instantly; a short delay stops seat swaps flickering the overlay)"
                           VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="6,0,0,0"/>
              </StackPanel>

              <StackPanel Orientation="Horizontal" Margin="0,0,0,6" VerticalAlignment="Center">
                <TextBlock Text="Label position" VerticalAlignment="Center" Width="120" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <ComboBox Width="150" FontSize="11"
                          SelectedValue="{Binding CornerOverlayLabelAnchor}" SelectedValuePath="Tag"
                          ToolTip="Where the character name sits inside its preview tile.">
                  <ComboBoxItem Tag="TopLeft" Content="Top left"/>
                  <ComboBoxItem Tag="TopCenter" Content="Top center"/>
                  <ComboBoxItem Tag="TopRight" Content="Top right"/>
                  <ComboBoxItem Tag="MiddleLeft" Content="Middle left"/>
                  <ComboBoxItem Tag="Center" Content="Center"/>
                  <ComboBoxItem Tag="MiddleRight" Content="Middle right"/>
                  <ComboBoxItem Tag="BottomLeft" Content="Bottom left"/>
                  <ComboBoxItem Tag="BottomCenter" Content="Bottom center"/>
                  <ComboBoxItem Tag="BottomRight" Content="Bottom right"/>
                </ComboBox>
                <TextBlock Text="master" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="12,0,0,0"/>
                <ComboBox Width="130" FontSize="11" Margin="6,0,0,0"
                          SelectedValue="{Binding CornerOverlayLabelAnchorMaster}" SelectedValuePath="Tag"
                          ToolTip="Where the label sits on the big center/master rect. That is the client you are actually looking at, so a label parked in the middle of it covers your ship - top usually reads better there while the small tiles stay centered.">
                  <ComboBoxItem Tag="TopLeft" Content="Top left"/>
                  <ComboBoxItem Tag="TopCenter" Content="Top center"/>
                  <ComboBoxItem Tag="TopRight" Content="Top right"/>
                  <ComboBoxItem Tag="MiddleLeft" Content="Middle left"/>
                  <ComboBoxItem Tag="Center" Content="Center"/>
                  <ComboBoxItem Tag="MiddleRight" Content="Middle right"/>
                  <ComboBoxItem Tag="BottomLeft" Content="Bottom left"/>
                  <ComboBoxItem Tag="BottomCenter" Content="Bottom center"/>
                  <ComboBoxItem Tag="BottomRight" Content="Bottom right"/>
                </ComboBox>
                <TextBlock Text="edge inset" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="12,0,0,0"/>
                <TextBox Width="40" Margin="6,0,0,0"
                         Text="{Binding CornerOverlayLabelInset, UpdateSourceTrigger=PropertyChanged}"
                         HorizontalContentAlignment="Center" FontSize="11"
                         ToolTip="Gap in pixels between the label and the tile edge it hugs. Ignored on a centered axis."/>
                <TextBlock Text="px" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="4,0,0,0"/>
              </StackPanel>

              <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                <TextBlock Text="Zoom grows from" VerticalAlignment="Center" Width="120" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <ComboBox Width="130" FontSize="11"
                          SelectedValue="{Binding HoverZoomAnchor}" SelectedValuePath="Tag"
                          ToolTip="Which point a hover-zoomed tile expands from. Center grows evenly; an edge or corner pins that side so a tile against a screen edge grows inward instead of being clamped. Per-seat overrides live on each slot card in the Clients tab.">
                  <ComboBoxItem Tag="TopLeft" Content="Top left"/>
                  <ComboBoxItem Tag="TopCenter" Content="Top center"/>
                  <ComboBoxItem Tag="TopRight" Content="Top right"/>
                  <ComboBoxItem Tag="MiddleLeft" Content="Middle left"/>
                  <ComboBoxItem Tag="Center" Content="Center"/>
                  <ComboBoxItem Tag="MiddleRight" Content="Middle right"/>
                  <ComboBoxItem Tag="BottomLeft" Content="Bottom left"/>
                  <ComboBoxItem Tag="BottomCenter" Content="Bottom center"/>
                  <ComboBoxItem Tag="BottomRight" Content="Bottom right"/>
                </ComboBox>
              </StackPanel>

              <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                <TextBlock Text="Snap tiles to grid" VerticalAlignment="Center" Width="120" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <TextBox Width="48"
                         Text="{Binding CornerOverlaySnapGridPx, UpdateSourceTrigger=PropertyChanged}"
                         HorizontalContentAlignment="Center" FontSize="11"/>
                <TextBlock Text="px when dragging/resizing previews on the overlay (0 = free)"
                           VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="6,0,0,0"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                <TextBlock Text="Auto-close overlay after" VerticalAlignment="Center" Width="120" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <TextBox Width="48"
                         Text="{Binding OfflineOverlayTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}"
                         HorizontalContentAlignment="Center" FontSize="11"/>
                <TextBlock Text="sec of every seat offline (0 = never auto-close, default 60)" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="6,0,0,0"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                <TextBlock Text="Hide offline pill after" VerticalAlignment="Center" Width="120" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <TextBox Width="48"
                         Text="{Binding OfflinePillTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}"
                         HorizontalContentAlignment="Center" FontSize="11"/>
                <TextBlock Text="sec offline (0 = hide immediately, -1 = never hide, default)" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="6,0,0,0"/>
              </StackPanel>
              <TextBlock Text="Preview non-EVE apps" FontSize="13" FontWeight="SemiBold" Margin="0,14,0,6"/>
              <TextBlock TextWrapping="Wrap" LineHeight="20" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,8">
Apps listed here also show up as detected/assignable windows (Clients tab) so one can be assigned to a slot and previewed in a corner tile alongside your EVE clients -- e.g. Discord or a spreadsheet. Matched by process name (case-insensitive, partial match, no ".exe").
              </TextBlock>
              <ItemsControl ItemsSource="{Binding PreviewableApps}" Margin="0,0,0,6">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <DockPanel Margin="0,3">
                      <CheckBox DockPanel.Dock="Left" IsChecked="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
                      <Button DockPanel.Dock="Right" Content="Remove" Padding="7,3" FontSize="11" Margin="6,0,0,0"
                              Command="{Binding DataContext.RemovePreviewableAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}"/>
                      <TextBox Text="{Binding ProcessName, UpdateSourceTrigger=PropertyChanged}"
                               Width="180" Padding="6,4" FontSize="12"
                               ToolTip="Process name substring, case-insensitive (e.g. discord, excel)"/>
                    </DockPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <Button Content="+ Add App" Command="{Binding AddPreviewableAppCommand}" Padding="8,4" FontSize="12" HorizontalAlignment="Left"/>
                  </StackPanel>
                  <!-- section 8: Settings Backup -->
                  <StackPanel Visibility="{Binding SelectedIndex, ElementName=OptionsMenu, Converter={StaticResource IndexToVisibility}, ConverterParameter=8}">
                    <TextBlock Text="Settings Backup" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
              <TextBlock TextWrapping="Wrap" LineHeight="20" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,10">
EveDeck snapshots your settings on each launch (5 today + 1 per day for 7 days). Each entry shows how many slots and characters were saved. Select one below to restore it, or create a manual backup before making big changes. Export saves your current settings to any file; Import loads from a file and restarts.
              </TextBlock>

              <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <ComboBox ItemsSource="{Binding AvailableBackups}"
                          SelectedItem="{Binding SelectedBackup}"
                          DisplayMemberPath="DisplayName"
                          Width="260" Margin="0,0,8,0"/>
                <Button Content="Restore" Click="RestoreBackup_Click"
                        IsEnabled="{Binding HasSelectedBackup}"
                        ToolTip="Restore the selected backup and restart EveDeck"
                        MinWidth="80" Margin="0,0,6,0"/>
                <Button Content="Create backup now" Click="CreateBackup_Click"
                        MinWidth="130"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Button Content="Export settings..." Click="ExportSettings_Click"
                        MinWidth="140" Margin="0,0,8,0"
                        ToolTip="Save current settings.json to a file of your choice"/>
                <Button Content="Import settings..." Click="ImportSettings_Click"
                        MinWidth="140"
                        ToolTip="Load settings from a JSON file and restart EveDeck"/>
              </StackPanel>
                  </StackPanel>
                  <!-- section 9: Hotkey Behavior -->
                  <StackPanel Visibility="{Binding SelectedIndex, ElementName=OptionsMenu, Converter={StaticResource IndexToVisibility}, ConverterParameter=9}">
                    <TextBlock Text="Hotkey Behavior" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
              <CheckBox Content="Only fire hotkeys when an EVE client is the active window"
                        IsChecked="{Binding RequireEveFocusForHotkeys}"
                        Margin="0,0,0,6"/>
              <CheckBox Content="Suspend all hotkeys (panic pause)"
                        IsChecked="{Binding HotkeysSuspended}"
                        Margin="0,0,0,6"
                        ToolTip="Temporarily disables every EveDeck hotkey. Bind 'Suspend / resume all hotkeys' in the Hotkeys tab to toggle this from the keyboard — that one binding keeps working while suspended."/>
              <TextBlock TextWrapping="Wrap" LineHeight="20" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,4">
When on, swap/cycle/apply-layout hotkeys only work while an EVE client is the active window — and the keys pass through normally to other apps (browser, chat, etc.) the rest of the time. Focus-slot and character-switch hotkeys stay active everywhere so you can always jump back into EVE. Turn this off to make every hotkey global.
              </TextBlock>
                  </StackPanel>
                  <!-- section 10: Performance -->
                  <StackPanel Visibility="{Binding SelectedIndex, ElementName=OptionsMenu, Converter={StaticResource IndexToVisibility}, ConverterParameter=10}">
                    <TextBlock Text="Performance" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
              <CheckBox Content="Throttle background EVE clients to Below Normal CPU priority"
                        IsChecked="{Binding ThrottleBackgroundProcesses}"
                        Margin="0,0,0,4"/>
              <TextBlock TextWrapping="Wrap" LineHeight="20" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,10">
EveDeck lowers the OS scheduling priority of inactive EVE clients whenever another client is in the foreground, so the active one gets more CPU and GPU headroom. Tip: also set Options &gt; Display &amp; Graphics &gt; Limit background framerate to 1-5 FPS inside EVE itself for the biggest gain -- EVE handles its own render loop; EveDeck handles OS scheduling.
              </TextBlock>
              <CheckBox Content="Power-throttle background EVE clients (EcoQoS)"
                        IsChecked="{Binding EcoQosBackgroundClients}"
                        Margin="0,0,0,4"/>
              <CheckBox Content="Keep the next client in the cycle at full speed"
                        IsChecked="{Binding EcoQosExemptNextInCycle}"
                        IsEnabled="{Binding EcoQosBackgroundClients}"
                        Margin="16,0,0,4"/>
              <TextBlock TextWrapping="Wrap" LineHeight="20" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,10">
Asks Windows to park inactive clients on efficiency cores and clock them down -- a deeper cut than the priority drop above, and the two stack. The second box spares whichever client you would land on next when cycling, so it is already back at full speed by the time you get there.

EveDeck deliberately does NOT cap another client's frame rate: doing that means injecting a DLL into the EVE client to hook its render loop, which EveDeck will never do. EcoQoS is pure OS scheduling -- nothing is injected into, read from, or written to EVE. Requires Windows 10 1809 or newer; on older builds it logs once and stays off.
              </TextBlock>
              <CheckBox Content="Auto-minimize EVE clients that are not the active window"
                        IsChecked="{Binding AutoMinimizeInactiveClients}"
                        Margin="0,0,0,4"/>
              <TextBlock TextWrapping="Wrap" LineHeight="20" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,10">
Flat layouts only: whenever an EVE client takes focus, the others are minimized to save GPU/CPU. Ignored while corner overlays are live (minimized windows stop rendering, which would freeze the live previews). Seats marked "never minimize" on their slot card are always skipped -- as they are for the "Minimize all EVE clients" hotkey.
              </TextBlock>
                  </StackPanel>
                  <!-- section 11: EVE Launcher -->
                  <StackPanel Visibility="{Binding SelectedIndex, ElementName=OptionsMenu, Converter={StaticResource IndexToVisibility}, ConverterParameter=11}">
                    <TextBlock Text="EVE Launcher" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
              <TextBlock TextWrapping="Wrap" LineHeight="20" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,8">
Used by each character set's "Launch" button. EveDeck checks the common install locations automatically; only set a path here if it isn't found there.
              </TextBlock>
              <TextBox Text="{Binding EveLauncherPathOverride, UpdateSourceTrigger=PropertyChanged}"
                       Padding="6,4" FontSize="12"
                       ToolTip="Custom path to eveLauncher.exe, e.g. D:\Games\EVE Online\eveLauncher.exe"/>
                  </StackPanel>
                  <!-- section 12: Game Event Alerts -->
                  <StackPanel Visibility="{Binding SelectedIndex, ElementName=OptionsMenu, Converter={StaticResource IndexToVisibility}, ConverterParameter=12}">
                    <TextBlock Text="Game Event Alerts" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
              <TextBlock TextWrapping="Wrap" LineHeight="20" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,10">
Watches EVE's gamelog files (Documents\EVE\logs\Gamelogs) for events on your OTHER clients -- combat, mining crystal breaks, fleet invites. By default a match shows a toast notification (plus an optional sound) over the game. "Glow" events instead pulse that seat's tile/master rect on the overlay -- for "this character is under attack right now" alerts where a toast per line would be constant spam (Combat is Glow by default). Passive log reading only -- never sends anything into an EVE client. Pattern is a case-insensitive text match against new log lines; "Focused" skips the alert when that character's window is already active.
              </TextBlock>
              <ItemsControl ItemsSource="{Binding GameEventRules}" Margin="0,0,0,6">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <DockPanel Margin="0,3">
                      <CheckBox DockPanel.Dock="Left" IsChecked="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
                      <Button DockPanel.Dock="Right" Content="Remove" Padding="7,3" FontSize="11" Margin="6,0,0,0"
                              Command="{Binding DataContext.RemoveGameEventRuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}"/>
                      <CheckBox DockPanel.Dock="Right" Content="Focused" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11"
                                IsChecked="{Binding SuppressWhenFocused, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="Skip the alert when this character's window is already in the foreground"/>
                      <CheckBox DockPanel.Dock="Right" Content="Sound" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11"
                                IsChecked="{Binding PlaySound, UpdateSourceTrigger=PropertyChanged}"/>
                      <CheckBox DockPanel.Dock="Right" Content="Glow" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11"
                                IsChecked="{Binding FlashOnTile, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="Pulse the seat's tile/master rect on the overlay instead of a toast notification"/>
                      <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                               Width="130" Padding="6,4" FontSize="12" Margin="0,0,8,0"
                               ToolTip="Display name for this event"/>
                      <TextBox Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                               Padding="6,4" FontSize="12"
                               ToolTip="Text to match in new gamelog lines (case-insensitive)"/>
                    </DockPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <Button Content="+ Add Event" Command="{Binding AddGameEventRuleCommand}" Padding="8,4" FontSize="12" HorizontalAlignment="Left"/>
              <CheckBox Content="Abyss Mode -- suppress Glow-event sound (keep the visual glow)" FontSize="12" Margin="0,10,0,0"
                        IsChecked="{Binding AbyssModeEnabled, UpdateSourceTrigger=PropertyChanged}"
                        ToolTip="Abyssal Deadspace can put up to three of your characters under simultaneous, expected combat damage -- toggle this on before a run so Combat's sound doesn't fire constantly. Turn it back off for normal play."/>
              <CheckBox Content="Notifications on top of previews and allow-listed apps" FontSize="12" Margin="0,6,0,0"
                        IsChecked="{Binding ToastsAboveOverlays, UpdateSourceTrigger=PropertyChanged}"
                        ToolTip="Keeps toast notifications above the corner-overlay previews and any Overlay Allow List app (Discord, Mumble, ...) for the few seconds they're on screen. Turn off to let those apps sit over your alerts instead."/>
                  </StackPanel>
                  <!-- section 13: Overlay Allow List -->
                  <StackPanel Visibility="{Binding SelectedIndex, ElementName=OptionsMenu, Converter={StaticResource IndexToVisibility}, ConverterParameter=13}">
                    <TextBlock Text="Overlay Allow List" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
              <TextBlock TextWrapping="Wrap" LineHeight="20" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,10">
Apps listed here stay visually above EveDeck's corner-overlay tiles/labels even while an EVE client has focus -- useful if you keep a voice chat, intel, or fitting tool window positioned over the game. Matched by process name (case-insensitive, partial match, no ".exe") -- e.g. "discord" matches Discord.exe.
              </TextBlock>
              <ItemsControl ItemsSource="{Binding OverlayAllowedApps}" Margin="0,0,0,6">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <DockPanel Margin="0,3">
                      <CheckBox DockPanel.Dock="Left" IsChecked="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
                      <Button DockPanel.Dock="Right" Content="Remove" Padding="7,3" FontSize="11" Margin="6,0,0,0"
                              Command="{Binding DataContext.RemoveOverlayAllowedAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}"/>
                      <TextBox Text="{Binding ProcessName, UpdateSourceTrigger=PropertyChanged}"
                               Width="180" Padding="6,4" FontSize="12"
                               ToolTip="Process name substring, case-insensitive (e.g. mumble, discord, pyfa)"/>
                    </DockPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <Button Content="+ Add App" Command="{Binding AddOverlayAllowedAppCommand}" Padding="8,4" FontSize="12" HorizontalAlignment="Left"/>
                  </StackPanel>

                  <!-- section 14: Notifications -->
                  <StackPanel Visibility="{Binding SelectedIndex, ElementName=OptionsMenu, Converter={StaticResource IndexToVisibility}, ConverterParameter=14}">
                    <TextBlock Text="Notifications" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBlock TextWrapping="Wrap" LineHeight="20" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,14" MaxWidth="640">
Controls where EveDeck's own toast popups appear on screen, and whether they're also mirrored into
Windows' own Notification Center (click the system clock) so they're still reviewable after the
popup itself has faded.
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                      <TextBlock Text="Popup position" VerticalAlignment="Center" Width="110" Foreground="{StaticResource MutedBrush}"/>
                      <ComboBox Width="220" SelectedValuePath="Tag" FontSize="12"
                                SelectedValue="{Binding ToastPosition}">
                        <ComboBoxItem Tag="TopLeft" Content="Top left"/>
                        <ComboBoxItem Tag="TopCenter" Content="Top center"/>
                        <ComboBoxItem Tag="TopRight" Content="Top right"/>
                        <ComboBoxItem Tag="BottomLeft" Content="Bottom left"/>
                        <ComboBoxItem Tag="BottomCenter" Content="Bottom center"/>
                        <ComboBoxItem Tag="BottomRight" Content="Bottom right (above system clock)"/>
                      </ComboBox>
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,10" MaxWidth="500">
Takes effect the next time a toast is shown (or after restarting EveDeck).
                    </TextBlock>
                    <CheckBox Content="Mirror alerts into the Windows Notification Center" FontSize="12"
                              IsChecked="{Binding NativeNotificationCenterEnabled, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,6,0,0" MaxWidth="500">
Silently sends a copy of every alert to Windows itself (no second popup -- EveDeck's own toast stays
the only visible one), so your alert history is still there from the system clock's flyout even
after the popup has disappeared. Depends on Windows notifications being allowed for EveDeck in
Settings &gt; System &gt; Notifications.
                    </TextBlock>
                  </StackPanel>

                  <!-- section 15: Comms -->
                  <StackPanel Visibility="{Binding SelectedIndex, ElementName=OptionsMenu, Converter={StaticResource IndexToVisibility}, ConverterParameter=15}">
                    <TextBlock Text="Comms" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBlock TextWrapping="Wrap" LineHeight="20" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,10">
EveDeck's own who-is-talking panel for Mumble, fed by a small companion plugin that runs inside your Mumble client. Drag it anywhere on screen and use the lock icon to stop accidental drags.
                    </TextBlock>

                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="14" MaxWidth="480">
                      <StackPanel>
                        <DockPanel>
                          <CheckBox DockPanel.Dock="Right" Content="Enabled" IsChecked="{Binding TalkerOverlayEnabled}"/>
                          <TextBlock Text="Talker Overlay (Mumble plugin)" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                        </DockPanel>
                        <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0">
EveDeck's own who-is-talking panel, styled to match the app -- no Mumble window wrangling. Needs the EveDeck plugin installed once and enabled inside Mumble (Configure &gt; Plugins &gt; "EveDeck Talker Bridge"). Read-only: the plugin only reports names and talking state, never audio or messages.
                        </TextBlock>
                        <TextBlock Text="{Binding TalkerOverlayStatus}" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                          <TextBlock Text="Opacity" VerticalAlignment="Center" Width="80" Foreground="{StaticResource MutedBrush}"/>
                          <Slider Minimum="20" Maximum="100"
                                  Value="{Binding TalkerOverlayOpacity}"
                                  Width="180"
                                  VerticalAlignment="Center"
                                  IsSnapToTickEnabled="True"
                                  TickFrequency="5"/>
                          <TextBlock Text="{Binding TalkerOverlayOpacity, StringFormat={}{0}%}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                          <Button Content="Install plugin into Mumble" Command="{Binding InstallMumblePluginCommand}" Padding="10,4"/>
                        </StackPanel>
                        <TextBlock Text="{Binding MumblePluginInstallStatus}" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"/>
                      </StackPanel>
                    </Border>
                  </StackPanel>

                  <!-- section 16: Config Profiles -->
                  <StackPanel Visibility="{Binding SelectedIndex, ElementName=OptionsMenu, Converter={StaticResource IndexToVisibility}, ConverterParameter=16}">
                    <TextBlock Text="Config Profiles" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBlock TextWrapping="Wrap" LineHeight="20" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,10">
One named switch for your whole setup - "Mining" vs "PvP". A config profile remembers which layout and which character set to use, plus every overlay appearance setting (labels, colors, zoom, hide rules). Switch between them from the EveDeck tray icon.

Add captures whatever you have set up right now. Save re-captures the current setup into an existing profile. The layout and character set are remembered by reference, so editing a layout updates every config profile that uses it.
                    </TextBlock>

                    <ItemsControl ItemsSource="{Binding ConfigProfiles}" Margin="0,0,0,8">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                                  BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                            <DockPanel>
                              <Button DockPanel.Dock="Right" Content="Remove" Padding="7,3" FontSize="11" Margin="6,0,0,0"
                                      Command="{Binding DataContext.RemoveConfigProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                      CommandParameter="{Binding}"/>
                              <Button DockPanel.Dock="Right" Content="Save current" Padding="7,3" FontSize="11" Margin="6,0,0,0"
                                      ToolTip="Re-capture the current layout, character set and overlay appearance into this profile."
                                      Command="{Binding DataContext.SaveCurrentToConfigProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                      CommandParameter="{Binding}"/>
                              <Button DockPanel.Dock="Right" Content="Apply" Padding="7,3" FontSize="11" Margin="6,0,0,0"
                                      Command="{Binding DataContext.ApplyConfigProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                      CommandParameter="{Binding}"/>
                              <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                       Padding="6,4" FontSize="12" VerticalAlignment="Center"/>
                            </DockPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="+ Add config profile from current setup" Command="{Binding AddConfigProfileCommand}"
                            Padding="8,4" FontSize="12" HorizontalAlignment="Left" Margin="0,0,0,10"/>

                    <CheckBox Content="Re-apply the last used config profile on startup"
                              IsChecked="{Binding ApplyConfigProfileOnStartup}"
                              ToolTip="Applies after the startup layout profile, so a config profile always gets the last word."
                              Margin="0,0,0,10"/>
                  </StackPanel>
                </Grid>
              </ScrollViewer>
            </Grid>
          </Grid>
        </TabItem>

        <!-- ──────────────────── MONITORS TAB ──────────────────── -->
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center"/>
              <TextBlock Text="Monitors" VerticalAlignment="Center"/>
            </StackPanel>
          </TabItem.Header>
          <Grid Margin="8">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
              <Button Content="Refresh" Command="{Binding RefreshCommand}"/>
              <CheckBox Content="Use physical pixels" IsChecked="{Binding UsePhysicalPixels}" VerticalAlignment="Center"/>
              <TextBlock Text="Your displays and their exact pixel coordinates, used when placing layouts. If positions look off, toggle 'Use physical pixels' — Windows display scaling can otherwise shift the numbers."
                         VerticalAlignment="Center"
                         Foreground="{StaticResource MutedBrush}"
                         FontSize="11"
                         TextWrapping="Wrap"
                         MaxWidth="520"
                         Margin="8,0"/>
            </StackPanel>
            <Grid Grid.Row="1">
              <Grid.RowDefinitions>
                <RowDefinition Height="240"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <Border Background="{StaticResource PanelBrush}"
                      BorderBrush="{StaticResource BorderBrush}"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="10"
                      Margin="0,0,0,8">
                <Canvas ClipToBounds="True">
                  <ItemsControl ItemsSource="{Binding MonitorPreviewItems}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <Canvas/>
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                      <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                      </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Width="{Binding Width}" Height="{Binding Height}"
                                Background="#0E1C30"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="2"
                                CornerRadius="4"
                                Padding="8">
                          <TextBlock Text="{Binding Label}" TextWrapping="Wrap" FontWeight="SemiBold" FontSize="11"/>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Canvas>
              </Border>
              <DataGrid Grid.Row="1" ItemsSource="{Binding Monitors}" IsReadOnly="True">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="130"/>
                  <DataGridCheckBoxColumn Header="Primary" Binding="{Binding IsPrimary}" Width="70"/>
                  <DataGridTextColumn Header="X" Binding="{Binding Bounds.X}" Width="65"/>
                  <DataGridTextColumn Header="Y" Binding="{Binding Bounds.Y}" Width="65"/>
                  <DataGridTextColumn Header="Width" Binding="{Binding Bounds.Width}" Width="75"/>
                  <DataGridTextColumn Header="Height" Binding="{Binding Bounds.Height}" Width="75"/>
                  <DataGridTextColumn Header="Work X" Binding="{Binding WorkArea.X}" Width="65"/>
                  <DataGridTextColumn Header="Work Y" Binding="{Binding WorkArea.Y}" Width="65"/>
                  <DataGridTextColumn Header="Work W" Binding="{Binding WorkArea.Width}" Width="75"/>
                  <DataGridTextColumn Header="Work H" Binding="{Binding WorkArea.Height}" Width="75"/>
                  <DataGridTextColumn Header="DPI" Binding="{Binding DpiX}" Width="60"/>
                  <DataGridTextColumn Header="Scale %" Binding="{Binding ScalePercent}" Width="65"/>
                </DataGrid.Columns>
              </DataGrid>
            </Grid>
          </Grid>
        </TabItem>

        <!-- ──────────────────── COMMS TAB ──────────────────── -->
        <!-- ──────────────────── PLANETS TAB ──────────────────── -->
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center"/>
              <TextBlock Text="Planetary Industry" VerticalAlignment="Center"/>
            </StackPanel>
          </TabItem.Header>
          <Grid Margin="12">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
              <TextBlock Text="Planetary Industry" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4"/>
              <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12" MaxWidth="720">
                A read-only monitor of your linked characters' colonies, straight from ESI — extractor
                countdowns and storage fill, with a seat flash + sound when an extractor is about to
                expire or a storage nears full. Needs each character linked (Clients tab) with the
                Planetary Industry and skills scopes granted — use the ↻ re-auth button there if a
                character was linked before those scopes existed. EveDeck never changes anything in-game here.
              </TextBlock>

              <!-- Controls row -->
              <DockPanel Margin="0,0,0,10">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                  <Button Content="Refresh now" Command="{Binding RefreshPiCommand}" Padding="10,4" Margin="0,0,8,0"/>
                  <CheckBox Content="Enabled" IsChecked="{Binding PiEnabled}" VerticalAlignment="Center"/>
                </StackPanel>
                <WrapPanel VerticalAlignment="Center">
                  <TextBlock Text="Poll every" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                  <TextBox Text="{Binding PiRefreshMinutes}" Width="42" Margin="6,0" VerticalAlignment="Center"/>
                  <TextBlock Text="min · alert extractor within" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                  <TextBox Text="{Binding PiExtractorAlertHours}" Width="42" Margin="6,0" VerticalAlignment="Center"/>
                  <TextBlock Text="h · storage over" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                  <TextBox Text="{Binding PiStorageAlertPercent}" Width="42" Margin="6,0" VerticalAlignment="Center"/>
                  <TextBlock Text="%" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                </WrapPanel>
              </DockPanel>
              <TextBlock Text="{Binding PiStatus}" Foreground="{StaticResource MutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <StackPanel>

                <!-- Factory-load calculator -->
                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                  <StackPanel>
                    <TextBlock Text="Factory-load calculator" FontWeight="SemiBold" FontSize="14"/>
                    <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,10" MaxWidth="720">
                      Auto-detects every material your own colonies' facilities actually consume — P1
                      through P4, whatever tier you run — learned from their real recipes, and totals
                      each against ESI assets, then splits the scarcest one evenly across your factory
                      planets. Recomputes on every refresh — add a material manually below only for
                      something not yet detected.
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                      <TextBlock Text="Total stock from" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                      <ComboBox ItemsSource="{Binding PiConsolidationOptions}"
                                SelectedItem="{Binding PiConsolidationSelection}"
                                Width="220"
                                ToolTip="Pick whoever consolidates hauled PI materials in from your extractor alts, so the split is based on what's actually staged and ready — not double-counted across every character.">
                        <ComboBox.ItemTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}"/>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                    </StackPanel>

                    <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4" MaxWidth="720">
                      Uncheck a material to stop it gating the split — e.g. an intermediate tier your
                      colonies consume entirely on-planet (chained straight into the next facility)
                      rather than actually haul, which would otherwise read ~0 and zero out the whole
                      calculation.
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding PiFactoryInputs}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <DockPanel Margin="0,2" MaxWidth="360" HorizontalAlignment="Left">
                            <Button DockPanel.Dock="Right" Content="✕" Width="22" Padding="0"
                                    Command="{Binding DataContext.RemoveFactoryInputCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}">
                              <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAuto}" Value="True">
                                      <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </Button.Style>
                            </Button>
                            <TextBlock DockPanel.Dock="Right" Text="{Binding AvailableText}" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <CheckBox DockPanel.Dock="Left" IsChecked="{Binding IncludeInSplit}" VerticalAlignment="Center" Margin="0,0,6,0"
                                      ToolTip="Include this material's stock in the scarcest-input split calculation"/>
                            <TextBlock Text="{Binding Name}" FontSize="12" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                          </DockPanel>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                      <TextBox Text="{Binding PiFactoryInputEntry, UpdateSourceTrigger=PropertyChanged}" Width="80" VerticalAlignment="Center" ToolTip="EVE type id"/>
                      <Button Content="Add input" Command="{Binding AddFactoryInputCommand}" Padding="8,3" Margin="6,0,0,0"/>
                    </StackPanel>

                    <WrapPanel Margin="0,10,0,0" VerticalAlignment="Center">
                      <TextBlock Text="Factories" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                      <TextBox Text="{Binding PiFactoryCount}" Width="48" Margin="6,0,14,0" VerticalAlignment="Center"/>
                      <TextBlock Text="Burn / hr each" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                      <TextBox Text="{Binding PiFactoryBurnPerHour}" Width="56" Margin="6,0,14,0" VerticalAlignment="Center"/>
                      <Button Content="Recompute now" Command="{Binding RunFactoryCalcCommand}" Padding="10,4"/>
                    </WrapPanel>

                    <TextBlock Text="{Binding PiCalcSummary}" Foreground="{StaticResource TextBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,10,0,0" MaxWidth="720"/>

                    <ItemsControl ItemsSource="{Binding PiCalcRows}" Margin="0,6,0,0">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <DockPanel Margin="0,1" MaxWidth="300" HorizontalAlignment="Left">
                            <TextBlock DockPanel.Dock="Right" Text="{Binding PerInputText}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock Text="{Binding Factory}" FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                          </DockPanel>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

                <!-- Colonies -->
                <ItemsControl ItemsSource="{Binding PiColonies}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                              BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                        <!-- Collapsed by default (15 PI characters = a lot of colonies); click the
                             header to expand. IsExpanded is carried across each refresh's wholesale
                             colony rebuild in MainWindowViewModel.Pi.cs. -->
                        <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}" HorizontalContentAlignment="Stretch">
                          <Expander.Header>
                            <DockPanel Margin="4,0,0,0" HorizontalAlignment="Stretch">
                              <TextBlock DockPanel.Dock="Right" Text="{Binding Headline}" Foreground="{StaticResource MutedBrush}" FontSize="11" VerticalAlignment="Center" Margin="16,0,0,0"/>
                              <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"/>
                                <Border Background="{StaticResource EsiChipBrush}" CornerRadius="3" Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                  <TextBlock Text="{Binding CharacterName}" FontSize="10" Foreground="{StaticResource TextBrush}"/>
                                </Border>
                                <TextBlock Text="{Binding UpgradeLevel, StringFormat=' · CC L{0}'}" Foreground="{StaticResource MutedBrush}" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding IcLevelText}" Foreground="{StaticResource MutedBrush}" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding PinCount, StringFormat=' · {0} pins'}" Foreground="{StaticResource MutedBrush}" FontSize="11" VerticalAlignment="Center"/>
                              </StackPanel>
                            </DockPanel>
                          </Expander.Header>

                          <StackPanel Margin="0,4,0,0">
                            <!-- Extractors -->
                            <ItemsControl ItemsSource="{Binding Extractors}" Margin="0,4,0,0">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <DockPanel Margin="0,2">
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding CountdownText}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center">
                                      <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                          <Setter Property="Foreground" Value="{StaticResource OnlineBrush}"/>
                                          <Style.Triggers>
                                            <DataTrigger Binding="{Binding State}" Value="ExpiringSoon">
                                              <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding State}" Value="Expired">
                                              <Setter Property="Foreground" Value="#EF4444"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding State}" Value="Idle">
                                              <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                                            </DataTrigger>
                                          </Style.Triggers>
                                        </Style>
                                      </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding DisplayName}" FontSize="12" Foreground="{StaticResource TextBrush}"/>
                                  </DockPanel>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Factories (Basic/Advanced/High-Tech Industry Facility pins — any tier, P1-P4) -->
                            <ItemsControl ItemsSource="{Binding Factories}" Margin="0,4,0,0">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <DockPanel Margin="0,2">
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding FillPercent, StringFormat={}{0:F0}%}" FontSize="11" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                    <StackPanel>
                                      <TextBlock Text="{Binding PinName}" FontSize="12" Foreground="{StaticResource TextBrush}"/>
                                      <TextBlock Text="{Binding RecipeText}" FontSize="10" Foreground="{StaticResource MutedBrush}"/>
                                    </StackPanel>
                                  </DockPanel>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Storage -->
                            <ItemsControl ItemsSource="{Binding Storages}" Margin="0,4,0,0">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <DockPanel Margin="0,1">
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding FillPercent, StringFormat={}{0:F0}%}" FontSize="11" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding PinName}" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                  </DockPanel>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </Expander>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

              </StackPanel>
            </ScrollViewer>
          </Grid>
        </TabItem>

        <!-- ──────────────────── DISCLAIMER TAB ──────────────────── -->
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center"/>
              <TextBlock Text="Disclaimer" VerticalAlignment="Center"/>
            </StackPanel>
          </TabItem.Header>
          <ScrollViewer Margin="16">
            <StackPanel MaxWidth="860" HorizontalAlignment="Left">
              <TextBlock Text="Disclaimer &amp; Fair Play Policy" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>
              <TextBlock TextWrapping="Wrap" LineHeight="22" Foreground="{StaticResource MutedBrush}">
EveDeck only manages OS-level window placement, border style, restore, and focus. It does not broadcast input. It does not automate gameplay. It does not read or modify EVE client memory. It does not inject DLLs. It does not log in for you or store EVE passwords.
              </TextBlock>
              <TextBlock TextWrapping="Wrap" LineHeight="22" Margin="0,12,0,0" Foreground="{StaticResource MutedBrush}">
Hotkeys are guarded in code so actions are limited to focusing one client, cycling focus, applying a layout, toggling or restoring borderless style, moving one active EVE window, or swapping one active EVE window with a slot. No action sends keyboard or mouse input to EVE, and no action sends a key or click to more than one EVE client.
              </TextBlock>
              <TextBlock Text="Blocked by design" FontSize="15" FontWeight="SemiBold" Margin="0,20,0,8"/>
              <TextBlock TextWrapping="Wrap" LineHeight="22" Foreground="{StaticResource MutedBrush}">
Input broadcasting, input multiplexing, gameplay key forwarding, mouse click forwarding, automation, memory reading, DLL injection, and login automation are outside the scope of this app and should not be added.
              </TextBlock>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <!-- ──────────────────── LOGS TAB ──────────────────── -->
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center"/>
              <TextBlock Text="Logs" VerticalAlignment="Center"/>
            </StackPanel>
          </TabItem.Header>
          <Grid Margin="8">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Activity and error log. If something isn't working, click Copy Diagnostics to copy a report you can share when asking for help."
                       Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="4,0,4,6" TextWrapping="Wrap"/>
            <!-- 2h: Log filter -->
            <DockPanel Grid.Row="1" Margin="0,0,0,4">
              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Level" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" Margin="0,0,8,0"/>
                <ComboBox SelectedItem="{Binding LogFilterLevel}" Width="80">
                  <sys:String>All</sys:String>
                  <sys:String>Info</sys:String>
                  <sys:String>Warn</sys:String>
                  <sys:String>Error</sys:String>
                </ComboBox>
              </StackPanel>
              <StackPanel Orientation="Horizontal">
                <Button Content="Copy Diagnostics" Command="{Binding CopyDiagnosticsCommand}"/>
                <Button Content="Refresh" Command="{Binding RefreshCommand}"/>
              </StackPanel>
            </DockPanel>
            <DataGrid Grid.Row="2" ItemsSource="{Binding LogsView}" IsReadOnly="True">
              <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Level}" Value="Error">
                      <Setter Property="Background" Value="#2A1420"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Level}" Value="Warn">
                      <Setter Property="Background" Value="#28221A"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </DataGrid.RowStyle>
              <DataGrid.Columns>
                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="175"/>
                <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="70"/>
                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </TabItem>

        <!-- ──────────────────── PROFILE SYNC TAB ──────────────────── -->
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center"/>
              <TextBlock Text="Profile Sync" VerticalAlignment="Center"/>
            </StackPanel>
          </TabItem.Header>
          <Grid Margin="12">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Folder selector row -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="Settings folder:" VerticalAlignment="Center"/>
              </StackPanel>
              <ComboBox Grid.Column="1"
                        ItemsSource="{Binding SettingsFolders}"
                        SelectedItem="{Binding SelectedSettingsFolder}"
                        DisplayMemberPath="DisplayName"
                        VerticalAlignment="Center"/>
              <Button Grid.Column="2" Content="Refresh" Command="{Binding RefreshSettingsFoldersCommand}"
                      Margin="8,0,0,0" VerticalAlignment="Center"/>
            </Grid>

            <!-- Source | Targets -->
            <Grid Grid.Row="1">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <!-- SOURCE panel -->
              <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="*"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="10,6" Margin="0,0,0,6">
                  <StackPanel>
                    <TextBlock Text="SOURCE" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,0,2"/>
                    <TextBlock Text="Copy settings from this character. Tip: the last client you closed has the freshest settings (sorted newest first)."
                               Foreground="{StaticResource MutedBrush}" FontSize="11" TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding CharacterProfiles}"
                         SelectedItem="{Binding SourceProfile}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal" Margin="2,3">
                        <Ellipse Width="36" Height="36" Margin="0,0,9,0" VerticalAlignment="Center"
                                 Style="{StaticResource PortraitDot}">
                          <Ellipse.Fill>
                            <ImageBrush ImageSource="{Binding Portrait.Image}" Stretch="UniformToFill"/>
                          </Ellipse.Fill>
                        </Ellipse>
                        <StackPanel VerticalAlignment="Center">
                          <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13"/>
                          <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                        </StackPanel>
                      </StackPanel>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock Grid.Row="2" Text="Account file (window positions live here) — auto-selected to match the source character"
                           Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="2,8,0,4"/>
                <ListBox Grid.Row="3" MaxHeight="140"
                         ItemsSource="{Binding AccountProfiles}"
                         SelectedItem="{Binding SourceAccountProfile}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Margin="2,3">
                        <TextBlock Text="{Binding DisplayName}" FontSize="12"/>
                        <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource MutedBrush}" FontSize="10"/>
                      </StackPanel>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>

              <!-- TARGETS panel -->
              <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="*"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="10,6" Margin="0,0,0,6">
                  <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                      <Button Content="All" Command="{Binding SelectAllProfileTargetsCommand}" Padding="8,2" Margin="0,0,4,0"/>
                      <Button Content="Clear" Command="{Binding ClearAllProfileTargetsCommand}" Padding="8,2"/>
                    </StackPanel>
                    <StackPanel>
                      <TextBlock Text="TARGETS" FontSize="10" FontWeight="Bold"
                                 Foreground="{StaticResource AccentBrush}" Margin="0,0,0,2"/>
                      <TextBlock Text="Check characters to receive the settings" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                    </StackPanel>
                  </DockPanel>
                </Border>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding CharacterProfiles}">
                  <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                      <Setter Property="Focusable" Value="False"/>
                    </Style>
                  </ListBox.ItemContainerStyle>
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                Margin="2,3" VerticalContentAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                          <Ellipse Width="36" Height="36" Margin="0,0,9,0" VerticalAlignment="Center"
                                   Style="{StaticResource PortraitDot}">
                            <Ellipse.Fill>
                              <ImageBrush ImageSource="{Binding Portrait.Image}" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                          </Ellipse>
                          <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                          </StackPanel>
                        </StackPanel>
                      </CheckBox>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock Grid.Row="2" Text="Account files to receive the account settings — auto-checked with their characters"
                           Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="2,8,0,4"/>
                <ListBox Grid.Row="3" MaxHeight="140"
                         ItemsSource="{Binding AccountProfiles}">
                  <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                      <Setter Property="Focusable" Value="False"/>
                    </Style>
                  </ListBox.ItemContainerStyle>
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="2,3"
                                VerticalContentAlignment="Center">
                        <StackPanel>
                          <TextBlock Text="{Binding DisplayName}" FontSize="12"/>
                          <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource MutedBrush}" FontSize="10"/>
                        </StackPanel>
                      </CheckBox>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Grid>

            <!-- Overwrite warning -->
            <TextBlock Grid.Row="2" Margin="0,10,0,0" TextWrapping="Wrap" FontSize="11"
                       Foreground="{StaticResource WarningBrush}"
                       Text="Warning: this overwrites the target characters' existing EVE UI settings. It does not touch EveDeck's own settings backups."/>

            <!-- Status + Copy button -->
            <Grid Grid.Row="3" Margin="0,10,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="{Binding ProfileCopyStatus}"
                         Foreground="{StaticResource MutedBrush}"
                         VerticalAlignment="Center" TextWrapping="Wrap" FontSize="12"/>
              <Button Grid.Column="1" Content="Copy Settings  →"
                      Command="{Binding ExecuteCopyProfilesCommand}"
                      Margin="16,0,0,0" Padding="14,6"
                      FontWeight="SemiBold"/>
            </Grid>
          </Grid>
        </TabItem>

        <!-- ──────────────────── ABOUT TAB ──────────────────── -->
        <TabItem x:Name="AboutTabItem">
          <TabItem.Header>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center"/>
              <TextBlock Text="About" VerticalAlignment="Center"/>
            </StackPanel>
          </TabItem.Header>
          <ScrollViewer Margin="16">
            <StackPanel MaxWidth="760" HorizontalAlignment="Left">

              <!-- Logo + title block -->
              <StackPanel Orientation="Horizontal" Margin="0,4,0,18">
                <Image Source="/Assets/evedeck-logo.png" Width="120" Height="120"
                       VerticalAlignment="Top" Margin="0,0,20,0"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="EveDeck" FontSize="24" FontWeight="Bold"/>
                  <TextBlock Text="A multibox toolkit for EVE Online -- EULA-safe window layout &amp; focus management, plus intel alerts and comms integrations."
                             Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="0,4,0,0" TextWrapping="Wrap" MaxWidth="420"/>
                  <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Border Background="#163527" CornerRadius="3" Padding="8,3">
                      <TextBlock Text="{Binding VersionText}" Foreground="#22C55E" FontWeight="SemiBold" FontSize="12"/>
                    </Border>
                    <TextBlock Text="EULA-conscious · no input broadcasting"
                               Foreground="{StaticResource MutedBrush}" FontSize="11"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Command="{Binding CheckForUpdateCommand}"
                            Padding="8,3" FontSize="11" Content="Check for Updates">
                      <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCheckingForUpdate}" Value="True">
                              <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Button.Style>
                    </Button>
                    <TextBlock Text="{Binding UpdateCheckStatusText}"
                               Foreground="{StaticResource MutedBrush}" FontSize="11"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                  </StackPanel>
                </StackPanel>
              </StackPanel>

              <!-- What it does -->
              <TextBlock Text="What it does" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6"/>
              <TextBlock TextWrapping="Wrap" LineHeight="20" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,16">
EveDeck arranges your EVE clients into tidy on-screen layouts and lets you jump between them with hotkeys. It can frame the active client, dim the ones you're not using, and show parked clients as live thumbnails in the screen corners — so a full multibox setup stays readable on a single monitor. It only moves, sizes, and focuses windows; it never plays the game for you.
              </TextBlock>

              <!-- A quick tour -->
              <TextBlock Text="The tabs at a glance" FontSize="15" FontWeight="SemiBold" Margin="0,4,0,8"/>
              <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="110"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Clients" FontWeight="SemiBold" FontSize="12" Margin="0,2,0,4"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Match each detected EVE window to a slot in your layout." Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,2,0,4" TextWrapping="Wrap"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Layouts" FontWeight="SemiBold" FontSize="12" Margin="0,2,0,4"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="Pick or design where the slots sit on screen, then apply it. Includes the AMD VSR / Nvidia DSR guide for giving the master slot more pixels." Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,2,0,4" TextWrapping="Wrap"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Hotkeys" FontWeight="SemiBold" FontSize="12" Margin="0,2,0,4"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="Bind keys to focus a client, cycle, or swap one into the master slot." Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,2,0,4" TextWrapping="Wrap"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Options" FontWeight="SemiBold" FontSize="12" Margin="0,2,0,4"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="Tune the active frame, dimming, previews, scaling, and startup." Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,2,0,4" TextWrapping="Wrap"/>
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Monitors" FontWeight="SemiBold" FontSize="12" Margin="0,2,0,4"/>
                <TextBlock Grid.Row="4" Grid.Column="1" Text="See your displays and their exact coordinates for placing layouts." Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,2,0,4" TextWrapping="Wrap"/>
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Disclaimer" FontWeight="SemiBold" FontSize="12" Margin="0,2,0,4"/>
                <TextBlock Grid.Row="5" Grid.Column="1" Text="Exactly what EveDeck will and won't do to your clients." Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,2,0,4" TextWrapping="Wrap"/>
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Logs" FontWeight="SemiBold" FontSize="12" Margin="0,2,0,4"/>
                <TextBlock Grid.Row="6" Grid.Column="1" Text="A running record of what EveDeck has done, for troubleshooting." Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,2,0,4" TextWrapping="Wrap"/>
                <TextBlock Grid.Row="7" Grid.Column="0" Text="Profile Sync" FontWeight="SemiBold" FontSize="12" Margin="0,2,0,4"/>
                <TextBlock Grid.Row="7" Grid.Column="1" Text="Mass-copy one character's EVE UI settings to multiple alts in one click." Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,2,0,4" TextWrapping="Wrap"/>
                <TextBlock Grid.Row="8" Grid.Column="0" Text="About" FontWeight="SemiBold" FontSize="12" Margin="0,2,0,4"/>
                <TextBlock Grid.Row="8" Grid.Column="1" Text="What EveDeck is, credits, and the version you're on." Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,2,0,4" TextWrapping="Wrap"/>
              </Grid>

              <Separator Margin="0,4,0,16"/>

              <!-- Credits -->
              <TextBlock Text="Credits" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6"/>
              <TextBlock TextWrapping="Wrap" LineHeight="20" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,16">
Built by the EveDeck project. Window management and live previews use native Windows APIs (Win32 and DWM) — live thumbnails are DWM window thumbnails, not screen capture. EVE Online is a trademark of Fenris Creations hf.; EveDeck is an unofficial, community-made tool and is not affiliated with or endorsed by Fenris Creations.
              </TextBlock>

              <!-- Compliance -->
              <TextBlock Text="Fair play" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6"/>
              <TextBlock TextWrapping="Wrap" LineHeight="20" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,8">
EveDeck is designed to respect EVE's one-input-to-one-client rule. It manages window placement and shows passive thumbnails only — it never broadcasts input, automates gameplay, reads client memory, or injects code. See the Disclaimer tab for the full policy.
              </TextBlock>

            </StackPanel>
          </ScrollViewer>
        </TabItem>

      </TabControl>
    </DockPanel>
    </Grid>
  </Border>
</Window>
