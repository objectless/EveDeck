<Window x:Class="EveDeck.Views.NewProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Custom Profile"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Background="#12161D">
  <StackPanel Margin="18" MinWidth="300">
    <TextBlock Text="New Custom Profile" Foreground="#EAF2FF" FontSize="15" FontWeight="SemiBold"/>
    <TextBlock Text="How many accounts should this layout have? You'll place each slot on your monitors next."
               Foreground="#8CA0B8" FontSize="12" TextWrapping="Wrap" Margin="0,6,0,12"/>
    <StackPanel Orientation="Horizontal">
      <TextBlock Text="Accounts" Foreground="#C9D6E8" VerticalAlignment="Center" Margin="0,0,10,0"/>
      <ComboBox x:Name="CountCombo" Width="80"/>
    </StackPanel>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Content="Create &amp; Place Slots" Click="OnOk" Padding="12,5" Margin="0,0,8,0" FontWeight="SemiBold"/>
      <Button Content="Cancel" Click="OnCancel" Padding="12,5"/>
    </StackPanel>
  </StackPanel>
</Window>
