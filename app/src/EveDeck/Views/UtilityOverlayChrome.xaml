<Window x:Class="EveDeck.Views.UtilityOverlayChrome"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="{StaticResource PanelBrush}"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Left="-10000" Top="-10000"
        Width="100" Height="100"
        MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="26"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Drag strip: the only chrome that's never covered by the real target window underneath,
         since the target is inset below/inside this window's edges (see UtilityOverlayChrome.Reposition). -->
    <Border x:Name="DragStrip" Grid.Row="0" Background="{StaticResource PanelAltBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
            MouseLeftButtonDown="DragStrip_MouseLeftButtonDown">
      <DockPanel Margin="6,0">
        <ToggleButton x:Name="LockToggle" DockPanel.Dock="Right"
                      Width="20" Height="18" Margin="4,0,0,0"
                      Click="LockToggle_Click"
                      ToolTip="Lock position and size">
          <ToggleButton.Style>
            <Style TargetType="ToggleButton">
              <Setter Property="Content" Value="&#x1F513;"/>
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="1"/>
              <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
              <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
              <Setter Property="FontSize" Value="10"/>
              <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                  <Setter Property="Content" Value="&#x1F512;"/>
                  <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                  <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                  <Setter Property="Foreground" Value="{StaticResource BgBrush}"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </ToggleButton.Style>
        </ToggleButton>
        <Button x:Name="DetachButton" DockPanel.Dock="Right"
                Content="&#x2715;" Width="20" Height="18" Margin="4,0,0,0"
                FontSize="10" Background="Transparent" BorderThickness="0" Foreground="{StaticResource MutedBrush}"
                Click="DetachButton_Click"
                ToolTip="Detach and restore this window's original size/position"/>
        <TextBlock x:Name="TitleText" VerticalAlignment="Center"
                   Foreground="{StaticResource TextBrush}" FontSize="11" FontWeight="SemiBold"/>
      </DockPanel>
    </Border>

    <!-- Border/backdrop: mostly occluded by the real target window sitting on top of it; only the
         margin around the edges (and the bottom-right resize grip) stays visible. That visible
         margin doubles as a resize handle for the left/right/bottom edges and corners (see
         BackdropBorder_MouseLeftButtonDown in code-behind). -->
    <Border x:Name="BackdropBorder" Grid.Row="1" Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,1,1"
            MouseLeftButtonDown="BackdropBorder_MouseLeftButtonDown"
            MouseMove="BackdropBorder_MouseMove"/>
    <Rectangle x:Name="ResizeGrip" Grid.Row="1" Width="14" Height="14" Fill="{StaticResource AccentBrush}"
               HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,2,2"
               Cursor="SizeNWSE"
               MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown"/>
  </Grid>
</Window>
