<Window x:Class="EveDeck.Views.CornerOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#111827"
        WindowStartupLocation="Manual">
  <!-- Pure video tile. The character-name label is drawn by a separate floating PillOverlay so it
       can sit on top of the DWM thumbnail / WGC swap chain (both of which draw over WPF content). -->
  <Border x:Name="CaptureHostContainer"/>
</Window>
