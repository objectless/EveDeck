<Window x:Class="EveDeck.Views.ActiveFrameOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Left="-10000" Top="-10000"
        Width="100" Height="100">
  <Grid>
    <!-- Corner brackets: four L-shapes marking the client rect's corners instead of a full
         perimeter, softened with a blur so they read as a glow. Geometry is built in ApplyFrame
         from the target size (the arms scale with the window). -->
    <Path x:Name="FrameBrackets" Fill="Transparent"
          StrokeThickness="8" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
      <Path.Effect>
        <BlurEffect x:Name="FrameBlur" Radius="6" KernelType="Gaussian"/>
      </Path.Effect>
    </Path>
  </Grid>
</Window>
