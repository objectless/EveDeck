<ResourceDictionary x:Class="EveDeck.Views.SeatCardTemplate"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Seat card for the Clients tab seat list (MainWindow's SlotsListBox). Split out of
       MainWindow.xaml purely to keep that file readable; the markup below is unchanged.
       Merged into Application.Resources by App.xaml. Its event handlers live in
       SeatCardTemplate.xaml.cs because a ResourceDictionary can only bind handlers to its own
       x:Class code-behind. -->

  <!-- Theme.xaml is merged here as well as in App.xaml. A DataTemplate in a standalone
       dictionary resolves StaticResource against this file's own parse-time scope, so without
       this merge every palette lookup below (and the BasedOn="{StaticResource {x:Type Button}}"
       implicit style) throws at render time. Source-loaded dictionaries are cached by URI, so
       this is the same instance App.xaml merges. -->
  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="Theme.xaml"/>
  </ResourceDictionary.MergedDictionaries>

  <DataTemplate x:Key="SeatCardTemplate">
    <StackPanel AllowDrop="True"
                DragEnter="SlotCard_DragEnter"
                DragLeave="SlotCard_DragLeave"
                DragOver="SlotCard_DragOver"
                Drop="SlotCard_Drop">

      <Border x:Name="SlotCardBorder" Padding="8,7">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
              <!-- Drop lands via Assignments.Move (insert, not swap), so show an
                   insert line on the leading edge rather than boxing the card. -->
              <DataTrigger Binding="{Binding IsDragSwapTarget}" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                <Setter Property="BorderThickness" Value="0,2,0,0"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="28"/>
            <ColumnDefinition Width="Auto" MinWidth="34"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <!-- Drag handle -->
          <!-- Full-height transparent grab strip: the glyph alone was a ~15x18px
               hit target. Background="Transparent" is required for hit-testing. -->
          <Border Grid.Column="0" Background="Transparent" Cursor="SizeAll"
                  VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                  ToolTip="Drag to reorder seats, or drop onto the mini-map to set this seat's corner. Alt+Up / Alt+Down reorders with the keyboard."
                  PreviewMouseLeftButtonDown="SlotHandle_MouseDown"
                  MouseMove="SlotHandle_MouseMove">
            <TextBlock Text="⠿" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Foreground" Value="#3A4A65"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                      <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </Border>

          <!-- Position-code pill -->
          <Border Grid.Column="1" MinWidth="26" Height="26" CornerRadius="13" Padding="7,0"
                  VerticalAlignment="Center" HorizontalAlignment="Left"
                  ToolTip="Screen position in the active layout (&#x2196; top-left, &#x2197; top-right, &#x2199; bottom-left, &#x2198; bottom-right, Master = main client)">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Background" Value="#1E2A3D"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsAssigned}" Value="True">
                    <Setter Property="Background" Value="{StaticResource OnlineChipBrush}"/>
                  </DataTrigger>
                  <DataTrigger Binding="{Binding IsMaster}" Value="True">
                    <Setter Property="Background" Value="{StaticResource MasterChipBrush}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <TextBlock Text="{Binding PositionCode}" HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontWeight="Bold" FontSize="11">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsAssigned}" Value="True">
                      <Setter Property="Foreground" Value="{StaticResource OnlineBrush}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsMaster}" Value="True">
                      <Setter Property="Foreground" Value="{StaticResource MasterAccentBrush}"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </Border>

          <!-- Label + character/window info -->
          <StackPanel Grid.Column="2" Margin="8,0" VerticalAlignment="Center">
            <!-- Slot name row -->
            <DockPanel>
              <Border DockPanel.Dock="Right" Background="{StaticResource MasterChipBrush}" CornerRadius="3" Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center"
                      ToolTip="This seat is the Master (home) seat.">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsMaster}" Value="True">
                        <Setter Property="Visibility" Value="Visible"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <TextBlock Text="MASTER" Foreground="{StaticResource MasterAccentBrush}" FontSize="9" FontWeight="Bold"/>
              </Border>
              <!-- Always-on-top pin toggle -->
              <ToggleButton DockPanel.Dock="Right"
                            IsChecked="{Binding IsTopmost, Mode=TwoWay}"
                            Command="{Binding DataContext.ToggleTopmostCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Content="&#x1F4CC;" FontSize="12"
                            Padding="7,1" Margin="4,0,0,0" MinWidth="0" MinHeight="0"
                            ToolTip="Keep this seat above other windows while EVE is focused. When you switch to a non-EVE app (browser, Discord) it drops back to normal so it doesn't cover them.">
                <ToggleButton.Style>
                  <Style TargetType="ToggleButton">
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                      <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                          <Border x:Name="bd" CornerRadius="3" Padding="{TemplateBinding Padding}"
                                  Background="Transparent"
                                  BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Border>
                          <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                              <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                              <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                              <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                              <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                              <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                          </ControlTemplate.Triggers>
                        </ControlTemplate>
                      </Setter.Value>
                    </Setter>
                  </Style>
                </ToggleButton.Style>
              </ToggleButton>
              <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                       Style="{StaticResource InlineSlotLabel}"
                       FontSize="14" FontWeight="SemiBold"
                       ToolTip="Slot label — auto-filled from 'EVE - Name'. Also editable in Options &gt; Character Names."/>
            </DockPanel>

            <!-- Style popup: consolidates label font/style/opacity (normal + MASTER) and frame color behind one button -->
            <StackPanel Margin="0,3,0,0">
              <Button x:Name="StyleButton" Content="Style..." Click="SlotStylePopup_Click"
                      Padding="7,3" MinWidth="0" MinHeight="0" FontSize="10" HorizontalAlignment="Left"
                      ToolTip="Edit this seat's label font/style/opacity (normal + MASTER) and active-frame color"/>
              <Popup x:Name="SeatStylePopup" PlacementTarget="{Binding ElementName=StyleButton}" Placement="Bottom"
                     StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade"
                     DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                <Border Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="14" MinWidth="360">
                  <StackPanel>
                    <TextBlock Text="Normal label" FontWeight="SemiBold" FontSize="11" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                      <Button Content="Font..." Click="SlotLabelFontPick_Click" Padding="6,2" FontSize="10"
                              ToolTip="Set this seat's preview label font, size and colour"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                      <CheckBox Content="Bold" Tag="Bold" Loaded="SlotStyleToggle_Loaded" Click="SlotStyleToggle_Click" Margin="0,0,10,0" FontSize="11" VerticalAlignment="Center"/>
                      <CheckBox Content="Italic" Tag="Italic" Loaded="SlotStyleToggle_Loaded" Click="SlotStyleToggle_Click" Margin="0,0,10,0" FontSize="11" VerticalAlignment="Center"/>
                      <CheckBox Content="Shadow" Tag="Shadow" Loaded="SlotStyleToggle_Loaded" Click="SlotStyleToggle_Click" Margin="0,0,10,0" FontSize="11" VerticalAlignment="Center"/>
                      <CheckBox Content="Outline" Tag="Outline" Loaded="SlotStyleToggle_Loaded" Click="SlotStyleToggle_Click" Margin="0,0,10,0" FontSize="11" VerticalAlignment="Center"/>
                      <TextBlock Text="Opacity" Margin="0,0,4,0" FontSize="11" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                      <Slider Tag="Opacity" Loaded="SlotOpacitySlider_Loaded" ValueChanged="SlotOpacitySlider_ValueChanged"
                              Minimum="20" Maximum="100" Width="100" VerticalAlignment="Center"/>
                      <Button Content="&#8635;" Click="SlotLabelStyleReset_Click" Padding="5,1" Margin="8,0,0,0" MinWidth="0" MinHeight="0" FontSize="10"
                              ToolTip="Reset this seat's label font, style and opacity to the global default"/>
                    </StackPanel>

                    <Separator Margin="0,0,0,10"/>

                    <TextBlock Text="Master label" FontWeight="SemiBold" FontSize="11" Foreground="{StaticResource MasterAccentBrush}" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                      <Button Content="Font..." Click="SlotMasterLabelFontPick_Click" Padding="6,2" FontSize="10"
                              ToolTip="Set this seat's label font/size/colour for when it's the centered MASTER seat (falls back to its normal label font when unset)"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                      <CheckBox Content="Bold" Tag="BoldMaster" Loaded="SlotStyleToggle_Loaded" Click="SlotStyleToggle_Click" Margin="0,0,10,0" FontSize="11" VerticalAlignment="Center"/>
                      <CheckBox Content="Italic" Tag="ItalicMaster" Loaded="SlotStyleToggle_Loaded" Click="SlotStyleToggle_Click" Margin="0,0,10,0" FontSize="11" VerticalAlignment="Center"/>
                      <CheckBox Content="Shadow" Tag="ShadowMaster" Loaded="SlotStyleToggle_Loaded" Click="SlotStyleToggle_Click" Margin="0,0,10,0" FontSize="11" VerticalAlignment="Center"/>
                      <CheckBox Content="Outline" Tag="OutlineMaster" Loaded="SlotStyleToggle_Loaded" Click="SlotStyleToggle_Click" Margin="0,0,10,0" FontSize="11" VerticalAlignment="Center"/>
                      <TextBlock Text="Opacity" Margin="0,0,4,0" FontSize="11" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                      <Slider Tag="OpacityMaster" Loaded="SlotOpacitySlider_Loaded" ValueChanged="SlotOpacitySlider_ValueChanged"
                              Minimum="20" Maximum="100" Width="100" VerticalAlignment="Center"/>
                      <Button Content="&#8635;" Click="SlotMasterLabelStyleReset_Click" Padding="5,1" Margin="8,0,0,0" MinWidth="0" MinHeight="0" FontSize="10"
                              ToolTip="Reset this seat's MASTER label font, style and opacity to the global master default"/>
                    </StackPanel>

                    <Separator Margin="0,0,0,10"/>

                    <TextBlock Text="Active frame" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                      <Button Content="Color..." Click="SlotFrameColorPick_Click" Padding="6,2" FontSize="10" Margin="0,0,4,0"
                              ToolTip="Set this seat's active-window frame colour (the highlight around the focused client)"/>
                      <Button Content="&#8635;" Click="SlotFrameColorReset_Click" Padding="5,1" MinWidth="0" MinHeight="0" FontSize="10" Margin="0,0,10,0"
                              ToolTip="Reset this seat's frame colour to the global default"/>
                      <Button Content="Paste Theme" Click="SlotPasteTheme_Click" Padding="6,2" FontSize="10"
                              ToolTip="Paste a copied EVE 'Edit Theme' string to set this seat's frame + label colour (Primary -&gt; frame, Accent -&gt; label)"/>
                    </StackPanel>

                    <Separator Margin="0,10,0,10"/>

                    <TextBlock Text="Label position and zoom" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                      <TextBlock Text="Label" FontSize="10" VerticalAlignment="Center"
                                 Foreground="{StaticResource MutedBrush}"/>
                      <ComboBox Width="96" FontSize="10" Margin="4,0,0,0"
                                SelectedValue="{Binding LabelAnchor, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Tag"
                                ToolTip="Where this seat's label sits on its small corner tile. Blank = use the global Label position from Options.">
                        <ComboBoxItem Tag="{x:Null}" Content="(inherit)"/>
                        <ComboBoxItem Tag="TopLeft" Content="Top left"/>
                        <ComboBoxItem Tag="TopCenter" Content="Top center"/>
                        <ComboBoxItem Tag="TopRight" Content="Top right"/>
                        <ComboBoxItem Tag="MiddleLeft" Content="Middle left"/>
                        <ComboBoxItem Tag="Center" Content="Center"/>
                        <ComboBoxItem Tag="MiddleRight" Content="Middle right"/>
                        <ComboBoxItem Tag="BottomLeft" Content="Bottom left"/>
                        <ComboBoxItem Tag="BottomCenter" Content="Bottom center"/>
                        <ComboBoxItem Tag="BottomRight" Content="Bottom right"/>
                      </ComboBox>
                      <TextBlock Text="as master" FontSize="10" VerticalAlignment="Center"
                                 Foreground="{StaticResource MutedBrush}" Margin="6,0,0,0"/>
                      <ComboBox Width="96" FontSize="10" Margin="4,0,0,0"
                                SelectedValue="{Binding LabelAnchorMaster, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Tag"
                                ToolTip="Where this seat's label sits when it is the big center/master client. Blank = use the global master position from Options.">
                        <ComboBoxItem Tag="{x:Null}" Content="(inherit)"/>
                        <ComboBoxItem Tag="TopLeft" Content="Top left"/>
                        <ComboBoxItem Tag="TopCenter" Content="Top center"/>
                        <ComboBoxItem Tag="TopRight" Content="Top right"/>
                        <ComboBoxItem Tag="MiddleLeft" Content="Middle left"/>
                        <ComboBoxItem Tag="Center" Content="Center"/>
                        <ComboBoxItem Tag="MiddleRight" Content="Middle right"/>
                        <ComboBoxItem Tag="BottomLeft" Content="Bottom left"/>
                        <ComboBoxItem Tag="BottomCenter" Content="Bottom center"/>
                        <ComboBoxItem Tag="BottomRight" Content="Bottom right"/>
                      </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="zoom" FontSize="10" VerticalAlignment="Center"
                                 Foreground="{StaticResource MutedBrush}"/>
                      <TextBox Text="{Binding ZoomFactor, UpdateSourceTrigger=PropertyChanged}"
                               Width="34" Padding="4,2" FontSize="10" Margin="4,0,0,0"
                               ToolTip="How hard this seat's preview magnifies on hover (1.5-8). Blank = use the global setting. Raise it for the one alt whose HUD you actually need to read."/>
                      <TextBlock Text="x from" FontSize="10" VerticalAlignment="Center"
                                 Foreground="{StaticResource MutedBrush}" Margin="6,0,0,0"/>
                      <ComboBox Width="96" FontSize="10" Margin="4,0,0,0"
                                SelectedValue="{Binding ZoomAnchor, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Tag"
                                ToolTip="Which point this tile grows from on hover zoom. Useful when a tile sits hard against a screen edge and should expand inward. Blank = use the global setting.">
                        <ComboBoxItem Tag="{x:Null}" Content="(inherit)"/>
                        <ComboBoxItem Tag="TopLeft" Content="Top left"/>
                        <ComboBoxItem Tag="TopCenter" Content="Top center"/>
                        <ComboBoxItem Tag="TopRight" Content="Top right"/>
                        <ComboBoxItem Tag="MiddleLeft" Content="Middle left"/>
                        <ComboBoxItem Tag="Center" Content="Center"/>
                        <ComboBoxItem Tag="MiddleRight" Content="Middle right"/>
                        <ComboBoxItem Tag="BottomLeft" Content="Bottom left"/>
                        <ComboBoxItem Tag="BottomCenter" Content="Bottom center"/>
                        <ComboBoxItem Tag="BottomRight" Content="Bottom right"/>
                      </ComboBox>
                    </StackPanel>
                  </StackPanel>
                </Border>
              </Popup>
            </StackPanel>

            <!-- Live indicator: who's actually logged into this seat right now, when
                 it differs from the seat's stable configured Label (e.g. an alt). -->
            <TextBlock Text="{Binding RunningCharacterName, StringFormat='Running: {0}'}"
                       FontSize="10" Foreground="{StaticResource MutedBrush}"
                       ToolTip="Character currently logged into this seat's window.">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Visibility" Value="Collapsed"/>
                  <Style.Triggers>
                    <MultiDataTrigger>
                      <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsAssigned}" Value="True"/>
                      </MultiDataTrigger.Conditions>
                      <Setter Property="Visibility" Value="Visible"/>
                    </MultiDataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>

            <!-- ESI characters -->
            <ItemsControl ItemsSource="{Binding EsiCharacters}" Margin="0,3,0,0">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,1">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Width="20" Height="20" Margin="0,0,6,0" VerticalAlignment="Center" Style="{StaticResource PortraitDot}">
                      <Ellipse.Fill>
                        <ImageBrush ImageSource="{Binding Portrait.Image}" Stretch="UniformToFill"/>
                      </Ellipse.Fill>
                    </Ellipse>
                    <Border Grid.Column="1" Background="{StaticResource EsiChipBrush}" CornerRadius="3" Padding="4,1" Margin="0,0,5,0" VerticalAlignment="Center"
                            ToolTip="ESI = EVE character login (SSO). This character is linked to this seat.">
                      <TextBlock Text="ESI" Foreground="{StaticResource AccentBrush}" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Grid.Column="2" Text="{Binding CharacterName}" FontSize="11" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                      <Button Content="↻"
                              Command="{Binding DataContext.ReauthEsiCharacterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}"
                              Padding="4,0" Margin="0" MinWidth="0" MinHeight="0" FontSize="11"
                              ToolTip="Re-run EVE SSO login for this character (e.g. to grant a newly added scope like Planetary Industry) without removing it from the seat"/>
                      <Button Content="×"
                              Command="{Binding DataContext.RemoveEsiCharacterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}"
                              Padding="4,0" Margin="4,0,0,0" MinWidth="0" MinHeight="0" FontSize="11"/>
                    </StackPanel>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Add ESI + assigned window summary on one compact row -->
            <DockPanel Margin="0,3,0,0">
              <Button DockPanel.Dock="Left"
                      Content="+ ESI"
                      Command="{Binding DataContext.AddEsiCharacterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                      CommandParameter="{Binding}"
                      Padding="5,2" Margin="0,0,6,0" MinHeight="0" FontSize="10"
                      ToolTip="ESI = EVE character login (SSO). Login with EVE SSO to link a character to this slot (main + up to 2 alts)">
                <Button.Style>
                  <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding EsiCharacters.Count}" Value="3">
                        <Setter Property="Visibility" Value="Collapsed"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Button.Style>
              </Button>
              <!-- Assigned window entries (compact inline) -->
              <ItemsControl ItemsSource="{Binding AssignedWindows}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="#111C2A" CornerRadius="3" Padding="5,2" Margin="0,0,4,0">
                      <DockPanel>
                        <Button DockPanel.Dock="Right" Content="×"
                                Command="{Binding DataContext.RemoveWindowFromSlotCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Padding="3,0" Margin="3,0,0,0" MinWidth="0" MinHeight="0" FontSize="10"/>
                        <TextBlock Text="{Binding Title}" FontSize="10"
                                   TextTrimming="CharacterEllipsis" MaxWidth="140"
                                   Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                      </DockPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </DockPanel>

            <!-- Unassigned hint -->
            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
              <StackPanel.Style>
                <Style TargetType="StackPanel">
                  <Setter Property="Visibility" Value="Collapsed"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsAssigned}" Value="False">
                      <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </StackPanel.Style>
              <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                         Foreground="{StaticResource WarningBrush}" VerticalAlignment="Center" Margin="0,0,5,0"/>
              <TextBlock Text="No window linked yet - select an EVE window above, then Assign"
                         Foreground="{StaticResource MutedBrush}" FontSize="10" VerticalAlignment="Center"/>
            </StackPanel>
          </StackPanel>

          <!-- Action buttons — compact vertical stack -->
          <StackPanel Grid.Column="3" Width="240" VerticalAlignment="Center" HorizontalAlignment="Right">
            <StackPanel Orientation="Horizontal">
              <Button Content="Assign"
                      Command="{Binding DataContext.AssignWindowToSlotCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                      CommandParameter="{Binding}" Padding="7,4" Margin="4,2"/>
              <Button Content="Focus"
                      Command="{Binding DataContext.FocusSlotCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                      CommandParameter="{Binding}" Padding="7,4" Margin="4,2"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
              <Button Content="Clear"
                      Command="{Binding DataContext.ClearSlotCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                      CommandParameter="{Binding}" Padding="6,3" Margin="4,2" FontSize="11"/>
              <Button Content="⭐ Master"
                      Command="{Binding DataContext.SetMasterSlotCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                      CommandParameter="{Binding}" Padding="6,3" Margin="4,2" FontSize="11"
                      ToolTip="Designate this slot as master for the swap-focused hotkey"/>
            </StackPanel>
            <CheckBox Content="Never minimize" FontSize="10" Margin="4,2"
                      IsChecked="{Binding NeverMinimize, UpdateSourceTrigger=PropertyChanged}"
                      ToolTip="Protect this seat from the Minimize-all hotkey and auto-minimize (e.g. a scout you always keep visible)"/>
            <CheckBox Content="Focus only (no master swap)" FontSize="10" Margin="4,2"
                      IsChecked="{Binding FocusOnlyNoSwap, UpdateSourceTrigger=PropertyChanged}"
                      ToolTip="Activating this seat (click/hotkey) just brings its window to the front in place, instead of swapping it into the master/center slot. Also disables hover-peek for this seat."/>
            <CheckBox Content="Hide preview" FontSize="10" Margin="4,2"
                      IsChecked="{Binding PreventPreview, UpdateSourceTrigger=PropertyChanged}"
                      ToolTip="Show this seat's corner tile as a plain colour instead of a live preview -- e.g. for a cloaky alt you don't want visible even as a thumbnail."/>
            <StackPanel Orientation="Horizontal" Margin="4,4,4,2">
              <TextBlock Text="Alias" FontSize="10" VerticalAlignment="Center"
                         Foreground="{StaticResource MutedBrush}"/>
              <TextBox Text="{Binding LabelAlias, UpdateSourceTrigger=PropertyChanged}"
                       Width="110" Padding="4,2" FontSize="10" Margin="4,0,0,0"
                       ToolTip="Show this text on the preview label instead of the character name. Blank = use the real name. Cosmetic only - window matching still uses the real name."/>
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>


    </StackPanel>
  </DataTemplate>

</ResourceDictionary>
