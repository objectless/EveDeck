<Application x:Class="EveDeck.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Application.Resources>
    <ResourceDictionary>
      <!-- Every brush and style now lives in Views/Theme.xaml; see the note at the top of that file
           for why it is a separate dictionary rather than inline here. App.Main additionally assigns
           the IndexToVisibility / BoolToVisibility converters straight into this top-level dictionary
           at runtime (App.xaml.cs), deliberately in code to avoid an xmlns:clr-namespace reference. -->
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Views/Theme.xaml"/>
        <ResourceDictionary Source="Views/SeatCardTemplate.xaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>
</Application>
